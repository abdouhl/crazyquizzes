---
import cardsData from '../data/cards.json';
import blitzesData from '../data/blitzes.json';
import Layout from '../layouts/Layout.astro';

const blitzCards = (cardsData as any[]).filter((c: any) => c.type === 'blitz');
const blitzes = blitzesData as Record<string, any>;

const pageDesc = `${blitzCards.length} free trivia blitz games — 10 questions, 10 seconds each. Test your knowledge of movies, music, flags, K-pop, science, and more. Can you beat the clock?`;
const canonicalURL = 'https://crazyquizzes.com/trivia-quizzes';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://crazyquizzes.com' },
        { '@type': 'ListItem', position: 2, name: 'Trivia Blitzes', item: canonicalURL },
      ],
    },
    {
      '@type': 'CollectionPage',
      '@id': canonicalURL,
      url: canonicalURL,
      name: 'Free Trivia Quizzes & Blitz Games Online — CrazyQuizzes',
      description: pageDesc,
      isPartOf: { '@id': 'https://crazyquizzes.com/#website' },
      publisher: { '@id': 'https://crazyquizzes.com/#organization' },
      mainEntity: {
        '@type': 'ItemList',
        name: 'Trivia Blitz Games',
        numberOfItems: blitzCards.length,
        itemListElement: blitzCards.map((card: any, i: number) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: card.title,
          url: `https://crazyquizzes.com/blitz/${card.id}`,
        })),
      },
    },
  ],
});

// Group by category for better UX
const categoryOrder = ['POP CULTURE', 'MUSIC', 'K-POP', 'MOVIES & TV', 'GEOGRAPHY', 'SCIENCE', 'HISTORY', 'SPORTS', 'TRIVIA', 'CHAOS'];
const grouped: Record<string, any[]> = {};
for (const card of blitzCards) {
  const cats = (card.categories as string[]).filter((c: string) => c !== 'ALL' && c !== 'TRIVIA');
  const primaryCat = cats[0] ?? 'TRIVIA';
  if (!grouped[primaryCat]) grouped[primaryCat] = [];
  grouped[primaryCat].push(card);
}
const orderedGroups = categoryOrder.filter(c => grouped[c]).map(c => ({ cat: c, cards: grouped[c] }));
const remaining = Object.entries(grouped).filter(([c]) => !categoryOrder.includes(c));
remaining.forEach(([c, cards]) => orderedGroups.push({ cat: c, cards }));
---
<Layout
  title="Free Trivia Quizzes & Blitz Games Online"
  description={pageDesc}
  canonical={canonicalURL}
  jsonLd={jsonLd}
>
  <nav class="page-breadcrumb" aria-label="Breadcrumb" style="font-family:'Bungee',cursive;font-size:11px;color:#6b6285;margin-bottom:22px;">
    <a href="/" style="color:#6c3bff;text-decoration:none;">Home</a>
    <span style="margin:0 6px;opacity:.5;">›</span>
    Trivia Blitzes
  </nav>

  <div class="page-badge">⚡ {blitzCards.length} BLITZ GAMES</div>
  <h1 class="page-title">TRIVIA<br><span style="color:#ffd23f;">BLITZES</span></h1>
  <div class="page-body">
    <p>Free trivia blitz games where speed matters as much as knowledge. Each blitz is 10 questions with a 10-second timer per question. No pausing. No mercy.</p>
    <p>Categories include movies, music, K-pop, flags, science, history, and complete chaos. Pick a topic, beat the clock, and challenge your friends.</p>
  </div>

  {orderedGroups.map(({ cat, cards }) => (
    <div style="margin-top:36px;">
      <h2 style="font-family:'Bungee',cursive;font-size:13px;color:#6c3bff;border-bottom:3px solid #1a1430;padding-bottom:8px;margin-bottom:16px;">
        {cat}
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;">
        {(cards as any[]).map((card: any) => {
          const blitz = blitzes[card.id];
          return (
            <a href={`/blitz/${card.id}`} style="text-decoration:none;color:inherit;display:block;">
              <div style="background:#1a1430;border:3px solid #1a1430;box-shadow:4px 4px 0 #6c3bff;padding:16px 18px;transition:transform .1s,box-shadow .1s;"
                   onmouseenter="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='6px 6px 0 #ffd23f'"
                   onmouseleave="this.style.transform='';this.style.boxShadow='4px 4px 0 #6c3bff'">
                <div style="font-family:'Bungee',cursive;font-size:10px;color:#3bffd2;margin-bottom:6px;">{card.cat}</div>
                <h2 style="font-family:'Bungee',cursive;font-size:14px;line-height:1.1;margin:0 0 8px;color:#ffd23f;">{card.title}</h2>
                {blitz?.desc && <p style="font-size:12px;line-height:1.4;color:#b3a9d6;margin:0 0 10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{blitz.desc}</p>}
                <div style="font-family:'Bungee',cursive;font-size:10px;color:#6b6285;">
                  <span style="color:#3bffd2;">10 Q</span> &nbsp;·&nbsp; <span style="color:#ff3b9a;">⏱ 10s EACH</span> &nbsp;·&nbsp; {card.takes} PLAYED
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  ))}

  <div style="margin-top:48px;" class="page-body">
    <h2>MORE QUIZZES</h2>
    <p>Want something that reveals your personality instead of testing your knowledge? Try our <a href="/personality-quizzes">Personality Quizzes</a>. Or <a href="/">browse all quizzes</a>.</p>
  </div>
</Layout>
