---
import comparesData from '../../data/compares.json';
import cardsData from '../../data/cards.json';

export function getStaticPaths() {
  return Object.keys(comparesData).map(id => ({ params: { id } }));
}

const { id } = Astro.params;
const compare = (comparesData as any)[id];
const card = (cardsData as any[]).find((c: any) => c.id === id);

const canonicalURL = `https://crazyquizzes.com/compare/${id}`;
const pageTitle = `${compare.title} — ${compare.subtitle} — CrazyQuizzes`;
const pageDesc = compare.desc;
const ogImage = `https://crazyquizzes.com/og-default.png`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://crazyquizzes.com/' },
        { '@type': 'ListItem', position: 2, name: `${compare.title} — ${compare.subtitle}`, item: canonicalURL },
      ],
    },
    {
      '@type': 'WebPage',
      '@id': canonicalURL,
      url: canonicalURL,
      name: pageTitle,
      description: pageDesc,
      isPartOf: { '@id': 'https://crazyquizzes.com/#website' },
      breadcrumb: { '@id': `${canonicalURL}#breadcrumb` },
    },
  ],
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CrazyQuizzes" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />
  <meta name="twitter:image" content={ogImage} />
  <script type="application/ld+json" set:html={jsonLd} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bungee&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #1a1430;
      color: #fff;
      font-family: 'Space Grotesk', sans-serif;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    #app {
      width: 100%;
      max-width: 860px;
      padding: 0 16px 32px;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    /* ── HEADER ── */
    .cq-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 0 20px;
    }
    .cq-back {
      font-size: 13px;
      color: #888;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: color .15s;
    }
    .cq-back:hover { color: #fff; }
    .cq-topic {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #666;
    }

    /* ── INTRO ── */
    .intro-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 24px;
      padding: 20px 0 40px;
      animation: cq-fadein .3s ease both;
    }
    .intro-cover {
      width: 140px;
      height: 140px;
      border-radius: 28px;
      background: linear-gradient(135deg,#2a1f50,#4a2080);
      border: 3px solid rgba(108,59,255,.4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 68px;
      filter: drop-shadow(0 8px 24px rgba(108,59,255,.4));
    }
    .intro-eyebrow {
      font-size: 11px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #ff3b9a;
    }
    .intro-title {
      font-family: 'Bungee', sans-serif;
      font-size: clamp(30px,7vw,48px);
      letter-spacing: 2px;
      line-height: 1;
    }
    .intro-subtitle {
      font-size: 14px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #aaa;
      margin-top: -12px;
    }
    .intro-desc {
      font-size: 15px;
      color: #bbb;
      max-width: 420px;
      line-height: 1.6;
    }
    .intro-chips {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .intro-chip {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 100px;
      padding: 6px 14px;
      font-size: 13px;
      color: #ccc;
    }
    .btn-play {
      background: #ff3b9a;
      color: #fff;
      border: none;
      font-family: 'Bungee', sans-serif;
      font-size: 18px;
      letter-spacing: 2px;
      padding: 18px 52px;
      border-radius: 100px;
      cursor: pointer;
      box-shadow: 0 4px 24px rgba(255,59,154,.45);
      transition: transform .15s, box-shadow .15s;
    }
    .btn-play:hover { transform: scale(1.04); box-shadow: 0 6px 32px rgba(255,59,154,.6); }
    .btn-play:active { transform: scale(.97); }
    .key-hint-intro {
      font-size: 12px;
      color: #555;
      letter-spacing: 1px;
    }
    .key-hint-intro kbd {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.15);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 11px;
      font-family: inherit;
    }

    /* ── GAME ── */
    .game-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 16px;
      animation: cq-fadein .25s ease both;
    }
    .game-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .game-label {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #555;
    }
    .score-pill {
      font-family: 'Bungee', sans-serif;
      font-size: 14px;
      background: rgba(255,210,63,.12);
      border: 1px solid rgba(255,210,63,.25);
      color: #ffd23f;
      padding: 6px 16px;
      border-radius: 100px;
      letter-spacing: 1px;
    }

    /* CARDS AREA */
    .cards-area {
      display: flex;
      align-items: stretch;
      gap: 12px;
      flex: 1;
      min-height: 0;
    }
    .vs-badge {
      flex-shrink: 0;
      align-self: center;
      font-family: 'Bungee', sans-serif;
      font-size: 13px;
      letter-spacing: 2px;
      color: #444;
      padding: 8px 4px;
    }

    /* individual compare card */
    .cmp-card {
      flex: 1;
      border-radius: 20px;
      padding: 28px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-align: center;
      min-height: 280px;
      position: relative;
      overflow: hidden;
      transition: border-color .3s, box-shadow .3s, background .3s;
    }
    .cmp-card-left {
      background: linear-gradient(145deg,#251850,#3c1f72);
      border: 2px solid rgba(108,59,255,.45);
    }
    .cmp-card-right {
      background: linear-gradient(145deg,#1a1a2e,#22203a);
      border: 2px dashed rgba(255,255,255,.12);
    }
    .cmp-card-right.revealed {
      border-style: solid;
    }
    .cmp-card.correct {
      background: linear-gradient(145deg,#0d2d1a,#0a3d20) !important;
      border-color: #3bffd2 !important;
      border-style: solid !important;
      box-shadow: 0 0 48px rgba(59,255,210,.25);
    }
    .cmp-card.wrong {
      background: linear-gradient(145deg,#2d0a1a,#3d0a20) !important;
      border-color: #ff3b9a !important;
      border-style: solid !important;
      box-shadow: 0 0 48px rgba(255,59,154,.25);
    }
    .cmp-card-emoji {
      font-size: 56px;
      line-height: 1;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,.5));
    }
    .cmp-card-name {
      font-family: 'Bungee', sans-serif;
      font-size: clamp(13px,2.5vw,17px);
      letter-spacing: 1px;
      color: #fff;
      line-height: 1.2;
    }
    .cmp-card-value {
      font-family: 'Bungee', sans-serif;
      font-size: clamp(22px,4.5vw,32px);
      color: #ffd23f;
      letter-spacing: 1px;
    }
    .cmp-card-unit {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #666;
      margin-top: -4px;
    }
    .cmp-card-fact {
      font-size: 12px;
      color: #888;
      line-height: 1.4;
      max-width: 170px;
      margin-top: 2px;
    }
    .cmp-mystery-value {
      font-family: 'Bungee', sans-serif;
      font-size: 36px;
      color: #333;
      letter-spacing: 6px;
    }
    .cmp-mystery-hint {
      font-size: 12px;
      color: #444;
      letter-spacing: 1px;
    }
    .cmp-result-icon {
      font-size: 36px;
      position: absolute;
      top: 12px;
      right: 16px;
    }

    /* ANSWER BUTTONS */
    .answer-btns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .answer-btn {
      border: none;
      border-radius: 14px;
      padding: 18px 12px;
      font-family: 'Bungee', sans-serif;
      font-size: clamp(13px,2.8vw,17px);
      letter-spacing: 2px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: transform .15s, box-shadow .15s, opacity .15s;
    }
    .btn-higher {
      background: #6c3bff;
      color: #fff;
      box-shadow: 0 4px 20px rgba(108,59,255,.4);
    }
    .btn-lower {
      background: #3bffd2;
      color: #1a1430;
      box-shadow: 0 4px 20px rgba(59,255,210,.3);
    }
    .answer-btn:hover:not(:disabled) { transform: translateY(-2px); }
    .answer-btn:active:not(:disabled) { transform: scale(.97); }
    .answer-btn:disabled { opacity: .4; cursor: not-allowed; }
    .btn-icon { font-size: 18px; }

    .key-hint {
      text-align: center;
      font-size: 11px;
      color: #444;
      letter-spacing: 1px;
    }
    .key-hint kbd {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 3px;
      padding: 1px 5px;
      font-size: 10px;
      font-family: inherit;
    }

    /* ── RESULTS ── */
    .results-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 24px;
      padding: 20px 0 40px;
      animation: cq-fadein .3s ease both;
    }
    .results-headline {
      font-family: 'Bungee', sans-serif;
      font-size: clamp(28px,7vw,44px);
      letter-spacing: 2px;
      line-height: 1.1;
    }
    .results-score-num {
      font-family: 'Bungee', sans-serif;
      font-size: clamp(64px,16vw,88px);
      color: #ffd23f;
      line-height: 1;
    }
    .results-score-sub {
      font-size: 12px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #666;
      margin-top: -4px;
    }
    .results-grade {
      font-family: 'Bungee', sans-serif;
      font-size: 20px;
      padding: 10px 28px;
      border-radius: 100px;
      letter-spacing: 1px;
    }
    .results-cta {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 100%;
      max-width: 340px;
    }
    .btn-again {
      background: #ff3b9a;
      color: #fff;
      border: none;
      font-family: 'Bungee', sans-serif;
      font-size: 15px;
      letter-spacing: 2px;
      padding: 16px;
      border-radius: 100px;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(255,59,154,.4);
      transition: transform .15s;
    }
    .btn-again:hover { transform: scale(1.03); }
    .btn-share-res {
      background: transparent;
      color: #3bffd2;
      border: 1px solid rgba(59,255,210,.3);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 14px;
      font-weight: 600;
      padding: 14px;
      border-radius: 100px;
      cursor: pointer;
      transition: all .15s;
    }
    .btn-share-res:hover { background: rgba(59,255,210,.08); }
    .btn-home-res {
      background: transparent;
      color: #666;
      border: 1px solid rgba(255,255,255,.1);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 14px;
      padding: 14px;
      border-radius: 100px;
      cursor: pointer;
      transition: color .15s, border-color .15s;
    }
    .btn-home-res:hover { color: #fff; border-color: rgba(255,255,255,.3); }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%) translateY(6px);
      background: #fff;
      color: #1a1430;
      font-family: 'Bungee', sans-serif;
      font-size: 12px;
      letter-spacing: 1px;
      padding: 10px 20px;
      border-radius: 100px;
      opacity: 0;
      transition: opacity .2s, transform .2s;
      pointer-events: none;
      white-space: nowrap;
      z-index: 999;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ANIMATIONS */
    @keyframes cq-fadein {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes cq-slidein {
      from { opacity: 0; transform: translateX(30px) scale(.96); }
      to   { opacity: 1; transform: translateX(0) scale(1); }
    }

    /* ── MOBILE ── */
    @media (max-width: 580px) {
      .cards-area {
        flex-direction: column;
        gap: 8px;
      }
      .cmp-card {
        min-height: 150px;
        flex-direction: row;
        text-align: left;
        padding: 18px 20px;
        gap: 14px;
        justify-content: flex-start;
      }
      .cmp-card-emoji { font-size: 40px; flex-shrink: 0; }
      .cmp-card-fact { display: none; }
      .vs-badge { align-self: center; font-size: 11px; }
      .answer-btns { gap: 10px; }
      .answer-btn { padding: 15px 10px; font-size: 13px; }
      .key-hint { display: none; }
    }
  </style>
</head>
<body>
  <div id="app"></div>
  <div class="toast" id="cq-toast"></div>

  <!-- Static fallback for crawlers -->
  <noscript>
    <div style="padding:32px;text-align:center;color:#fff">
      <h1>{compare.title} — {compare.subtitle}</h1>
      <p>{compare.desc}</p>
    </div>
  </noscript>

  <script define:vars={{ cData: compare, cId: id }}>
    const app   = document.getElementById('app');
    const toast = document.getElementById('cq-toast');

    /* ── helpers ── */
    let toastTimer;
    function showToast(msg) {
      clearTimeout(toastTimer);
      toast.textContent = msg;
      toast.classList.add('show');
      toastTimer = setTimeout(() => toast.classList.remove('show'), 2400);
    }

    function shuffle(arr) {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function e(s) {
      return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ── state ── */
    let state = { view: 'intro', items: [], idx: 0, score: 0, locked: false };

    function setState(patch) { Object.assign(state, patch); render(); }

    /* ── render ── */
    function render() {
      if (state.view === 'intro')   app.innerHTML = renderIntro();
      else if (state.view === 'game')    app.innerHTML = renderGame();
      else if (state.view === 'results') app.innerHTML = renderResults();
      wire();
    }

    function renderIntro() {
      const coverBg = cData.items[0]
        ? `linear-gradient(135deg,#2a1f50,#4a2080)`
        : `linear-gradient(135deg,#1a1430,#2a1430)`;
      return `
        <div class="cq-header">
          <a href="/" class="cq-back">← Home</a>
          <span class="cq-topic">${e(cData.metric)}</span>
        </div>
        <div class="intro-wrap">
          <div class="intro-cover">${e(cData.emoji)}</div>
          <div>
            <div class="intro-eyebrow">${e(cData.subtitle)}</div>
            <div class="intro-title">${e(cData.title)}</div>
          </div>
          <div class="intro-desc">${e(cData.desc)}</div>
          <div class="intro-chips">
            <span class="intro-chip">📊 ${cData.items.length} items</span>
            <span class="intro-chip">📏 ${e(cData.metric)} in ${e(cData.unit)}</span>
            <span class="intro-chip">⬆️ ${e(cData.higherLabel)} or ${e(cData.lowerLabel)}</span>
          </div>
          <button class="btn-play" data-a="start">▶ PLAY</button>
          <div class="key-hint-intro">Press <kbd>↑</kbd> / <kbd>↓</kbd> to answer</div>
        </div>
      `;
    }

    function leftCardHTML(item) {
      return `
        <div class="cmp-card cmp-card-left">
          <div class="cmp-card-emoji">${e(item.emoji)}</div>
          <div class="cmp-card-name">${e(item.name)}</div>
          <div class="cmp-card-value">${item.value.toLocaleString()}</div>
          <div class="cmp-card-unit">${e(cData.unit)}</div>
          <div class="cmp-card-fact">${e(item.fact)}</div>
        </div>
      `;
    }

    function rightCardHTML(item, revealed, correct) {
      if (!revealed) {
        return `
          <div class="cmp-card cmp-card-right" id="right-card">
            <div class="cmp-card-emoji">${e(item.emoji)}</div>
            <div class="cmp-card-name">${e(item.name)}</div>
            <div class="cmp-mystery-value">???</div>
            <div class="cmp-card-unit">${e(cData.unit)}</div>
            <div class="cmp-mystery-hint">${e(cData.higherLabel)} or ${e(cData.lowerLabel)}?</div>
          </div>
        `;
      }
      const cls = correct ? 'correct' : 'wrong';
      const icon = correct ? '✓' : '✗';
      return `
        <div class="cmp-card cmp-card-right revealed ${cls}" id="right-card" style="animation:cq-slidein .3s ease both">
          <div class="cmp-result-icon">${icon}</div>
          <div class="cmp-card-emoji">${e(item.emoji)}</div>
          <div class="cmp-card-name">${e(item.name)}</div>
          <div class="cmp-card-value">${item.value.toLocaleString()}</div>
          <div class="cmp-card-unit">${e(cData.unit)}</div>
          <div class="cmp-card-fact">${e(item.fact)}</div>
        </div>
      `;
    }

    function renderGame() {
      const left  = state.items[state.idx];
      const right = state.items[state.idx + 1];
      const dis   = state.locked ? 'disabled' : '';
      return `
        <div class="cq-header">
          <a href="/" class="cq-back">← Home</a>
          <div class="score-pill">⚡ ${state.score}</div>
        </div>
        <div class="game-wrap">
          <div class="game-topbar">
            <span class="game-label">${e(cData.higherLabel)} or ${e(cData.lowerLabel)}? — ${e(cData.subtitle)}</span>
          </div>
          <div class="cards-area" id="cards-area">
            ${leftCardHTML(left)}
            <div class="vs-badge">VS</div>
            ${rightCardHTML(right, false, false)}
          </div>
          <div class="answer-btns">
            <button class="answer-btn btn-higher" data-a="ans" data-higher="1" ${dis}>
              <span class="btn-icon">${e(cData.higherIcon)}</span>
              ${e(cData.higherLabel)}
            </button>
            <button class="answer-btn btn-lower" data-a="ans" data-higher="0" ${dis}>
              <span class="btn-icon">${e(cData.lowerIcon)}</span>
              ${e(cData.lowerLabel)}
            </button>
          </div>
          <div class="key-hint">Press <kbd>↑</kbd> ${e(cData.higherLabel)} · <kbd>↓</kbd> ${e(cData.lowerLabel)}</div>
        </div>
      `;
    }

    function renderResults() {
      const s   = state.score;
      const max = state.items.length - 1;
      const pct = max > 0 ? Math.round((s / max) * 100) : 0;
      let grade, gc;
      if (s === max)    { grade = '🏆 PERFECT';  gc = '#ffd23f'; }
      else if (pct >= 70) { grade = '🔥 SMART';    gc = '#ff3b9a'; }
      else if (pct >= 50) { grade = '🧠 DECENT';   gc = '#6c3bff'; }
      else if (pct >= 30) { grade = '😬 ROUGH';    gc = '#3bffd2'; }
      else                { grade = '💀 OUCH';     gc = '#888'; }

      return `
        <div class="cq-header">
          <a href="/" class="cq-back">← Home</a>
          <span class="cq-topic">${e(cData.metric)}</span>
        </div>
        <div class="results-wrap">
          <div class="results-headline">GAME<br>OVER</div>
          <div>
            <div class="results-score-num">${s}</div>
            <div class="results-score-sub">in a row</div>
          </div>
          <div class="results-grade" style="background:${gc}22;color:${gc};border:2px solid ${gc}44">${grade}</div>
          <div class="results-cta">
            <button class="btn-again" data-a="restart">↺ PLAY AGAIN</button>
            <button class="btn-share-res" data-a="share">📋 COPY SCORE</button>
            <button class="btn-home-res" onclick="location.href='/'">← MORE QUIZZES</button>
          </div>
        </div>
      `;
    }

    /* ── event wiring ── */
    function wire() {
      document.querySelectorAll('[data-a]').forEach(el => {
        el.addEventListener('click', onAction);
      });
    }

    function onAction(ev) {
      const a = ev.currentTarget.dataset.a;
      if (a === 'start')   startGame();
      else if (a === 'ans')     answer(ev.currentTarget.dataset.higher === '1');
      else if (a === 'restart') startGame();
      else if (a === 'share')   shareScore();
    }

    /* ── game logic ── */
    function startGame() {
      setState({ view: 'game', items: shuffle(cData.items), idx: 0, score: 0, locked: false });
    }

    function answer(playerChoseHigher) {
      if (state.locked) return;
      state.locked = true;

      const left  = state.items[state.idx];
      const right = state.items[state.idx + 1];

      // handle tie — auto-advance
      if (right.value === left.value) {
        showToast('⚖️ SAME VALUE — AUTO ADVANCE!');
        advanceOrEnd();
        return;
      }

      const correct = playerChoseHigher
        ? right.value > left.value
        : right.value < left.value;

      // reveal the right card in-place
      const area = document.getElementById('cards-area');
      if (area) {
        const rc = document.getElementById('right-card');
        if (rc) rc.outerHTML = rightCardHTML(right, true, correct);
        // also color left card
        const lc = area.querySelector('.cmp-card-left');
        if (lc) lc.classList.add(correct ? 'correct' : 'wrong');
      }

      if (correct) {
        state.score++;
        showToast('✓ CORRECT!');
        setTimeout(advanceOrEnd, 1050);
      } else {
        showToast(`✗ WRONG — it was ${right.value.toLocaleString()} ${cData.unit}`);
        setTimeout(() => setState({ view: 'results', locked: false }), 1600);
      }
    }

    function advanceOrEnd() {
      const nextIdx = state.idx + 1;
      if (nextIdx >= state.items.length - 1) {
        setState({ view: 'results', locked: false });
      } else {
        setState({ idx: nextIdx, locked: false });
      }
    }

    function shareScore() {
      const text = `I scored ${state.score} on "${cData.title} — ${cData.subtitle}"! Can you beat me? 👀\nhttps://crazyquizzes.com/compare/${cId}`;
      navigator.clipboard.writeText(text).then(() => showToast('✓ SCORE COPIED!'));
    }

    /* ── keyboard shortcuts ── */
    document.addEventListener('keydown', ev => {
      if (state.view !== 'game' || state.locked) return;
      if (ev.key === 'ArrowUp'   || ev.key === 'w') { ev.preventDefault(); answer(true); }
      if (ev.key === 'ArrowDown' || ev.key === 's') { ev.preventDefault(); answer(false); }
    });

    /* ── boot ── */
    render();
  </script>
</body>
</html>
