            </div>
          </section>

          <!-- CATEGORY CHIPS -->
          <section class="cat-chips" id="cat-chips-section">
            ${cats.map(cat => `
              <span class="chip${state.activeCat === cat.label ? ' chip--active' : ''}"
                style="background:${e(cat.color)};color:${e(cat.ink)};"
                data-action="filter" data-cat="${e(cat.label)}">${e(cat.label)}</span>
            `).join('')}
          </section>

          <!-- DAILY BLITZ BANNER -->
          <section id="daily-blitz">
            <a href="/blitz/${e(todayBlitzId)}" class="blitz-banner">
              <div class="blitz-bg-icon">⚡</div>
              <div style="position:relative;max-width:46ch;">
                <div class="blitz-eyebrow">⚡ NEW EVERY DAY · PLAY ALONG · BEAT THE CLOCK</div>
                <h2>TODAY'S <span class="yellow">BLITZ</span></h2>
                <p>${e(todayBlitz.title)} — 10 questions, 10 seconds each. How fast is your brain?</p>
