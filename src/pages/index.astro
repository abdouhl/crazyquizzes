      <span>✦ NEW QUIZZES EVERY DAMN DAY</span><span style="color:#ff3b9a;">✦ 2.3M QUIZZES TAKEN THIS WEEK</span><span style="color:#ffd23f;">✦ NO LOGIN. NO RULES. NO MERCY</span><span style="color:#3bffd2;">✦ 100% SCIENTIFICALLY INACCURATE</span><span>✦ NEW QUIZZES EVERY DAMN DAY</span><span style="color:#ff3b9a;">✦ 2.3M QUIZZES TAKEN THIS WEEK</span><span style="color:#ffd23f;">✦ NO LOGIN. NO RULES. NO MERCY</span><span style="color:#3bffd2;">✦ 100% SCIENTIFICALLY INACCURATE</span>
    </div>
  </div>

  <!-- HEADER -->
  <header>
    <div class="header-inner">
      <button class="logo" id="logo-btn" aria-label="Go home">
        <span class="logo-star">✦</span>
        <span class="logo-text"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></span>
      </button>
      <nav>
        <button id="nav-quizzes" class="nav-btn">QUIZZES</button>
        <a id="nav-blitz" class="nav-btn yellow" href="/">⚡ DAILY BLITZ</a>
        <button id="nav-random" class="nav-btn pink">🎲 RANDOM</button>
        <button id="nav-categories" class="nav-plain" style="background:none;border:none;cursor:pointer;">CATEGORIES</button>
        <a href="/about" class="nav-plain">ABOUT</a>
      </nav>
    </div>
  </header>

  <!-- MAIN APP -->
  <div id="app"></div>

  <!-- SHARE TOAST -->
  <div id="toast" class="toast" style="display:none;">✓ LINK COPIED — GO RUIN SOMEONE'S DAY</div>

  <script define:vars={{ cats: catsData, cards: cardsData, quizzes: quizzesData, blitzes: blitzesData }}>

    const hitDigits = ['0','0','4','2','0','6','9','1'];

    // ============================================================
    // STATE
    // ============================================================
    let state = {
      view: 'home',
      activeCat: 'ALL',
      activeQuizId: null,
      activeBlitzId: null,
      qIndex: 0,
      scores: {},
      result: null,
      shared: false,
      bIndex: 0,
      bTime: 10,
      bLocked: false,
      bPicked: null,
      bScore: 0,
      bStreak: 0,
    };

    let tickTimer = null;
    let advTimer = null;

    function setState(updates) {
      state = { ...state, ...updates };
      render();
    }

    // ============================================================
    // ACTIONS
    // ============================================================
    function goHome() {
      clearTimers();
      setState({ view: 'home', shared: false });
    }
    function filterCat(label) {
      if (state.view !== 'home') { setState({ view: 'home', activeCat: label, shared: false }); return; }
      setState({ activeCat: label });
      document.getElementById('cat-chips-section')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    function openCategories() {
      if (state.view !== 'home') { setState({ view: 'home', activeCat: 'ALL', shared: false }); return; }
      document.getElementById('cat-chips-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    function openRandom() {
      const card = cards[Math.floor(Math.random() * cards.length)];
      window.location.href = card.type === 'blitz' ? `/blitz/${card.id}` : `/quiz/${card.id}`;
    }
    function openQuiz(id) { window.location.href = '/quiz/' + id; }
    function startQuiz() { setState({ view: 'question', qIndex: 0, scores: {}, result: null }); }
    function retakeQuiz() { setState({ view: 'question', qIndex: 0, scores: {}, result: null, shared: false }); }

    function pickAnswer(key) {
      const quiz = quizzes[state.activeQuizId];
      const scores = { ...state.scores };
      scores[key] = (scores[key] || 0) + 1;
      const next = state.qIndex + 1;
      if (next >= quiz.questions.length) {
        const keys = Object.keys(quiz.results);
        const winner = keys.reduce((a, b) => ((scores[b] || 0) > (scores[a] || 0) ? b : a), keys[0]);
        setState({ scores, result: winner, view: 'results' });
      } else {
        setState({ scores, qIndex: next });
      }
    }

    function openBlitz(id) { window.location.href = '/blitz/' + id; }
    function startBlitz() {
      clearTimers();
      setState({ view: 'bquestion', bIndex: 0, bTime: 10, bLocked: false, bPicked: null, bScore: 0, bStreak: 0 });
      tickTimer = setInterval(tick, 1000);
    }
    function tick() {
      if (state.view !== 'bquestion' || state.bLocked) return;
      const t = state.bTime - 1;
      if (t <= 0) { setState({ bTime: 0 }); lockBlitz(-1); }
      else setState({ bTime: t });
    }
    function lockBlitz(idx) {
      if (state.bLocked) return;
      const blitz = blitzes[state.activeBlitzId];
      const q = blitz.questions[state.bIndex];
      const correct = idx === q.correct;
      setState({
        bLocked: true,
        bPicked: idx,
        bScore: state.bScore + (correct ? 1 : 0),
        bStreak: correct ? state.bStreak + 1 : 0,
      });
      advTimer = setTimeout(nextBlitz, 1500);
    }
    function nextBlitz() {
      const blitz = blitzes[state.activeBlitzId];
      const next = state.bIndex + 1;
      if (next >= blitz.questions.length) { clearTimers(); setState({ view: 'bresults' }); }
      else setState({ bIndex: next, bTime: 10, bLocked: false, bPicked: null });
    }
    function clearTimers() { clearInterval(tickTimer); clearTimeout(advTimer); }
    function doShare() {
      navigator.clipboard.writeText(window.location.href).catch(() => {});
      showToast('✓ LINK COPIED — GO RUIN SOMEONE\'S DAY');
    }
    function doShareTikTok() {
      const url = window.location.href;
      if (navigator.share) {
        navigator.share({ title: document.title, url }).catch(() => {});
      } else {
        navigator.clipboard.writeText(url).catch(() => {});
        showToast('LINK COPIED — PASTE IT IN YOUR TIKTOK BIO 🎵');
      }
    }
    function doShareInsta() {
      const url = window.location.href;
      if (navigator.share) {
        navigator.share({ title: document.title, url }).catch(() => {});
      } else {
        navigator.clipboard.writeText(url).catch(() => {});
        showToast('LINK COPIED — ADD IT TO YOUR INSTA STORY 📸');
      }
    }
    function showToast(msg) {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg;
      t.style.display = 'block';
      clearTimeout(showToast._tid);
      showToast._tid = setTimeout(() => { t.style.display = 'none'; }, 2800);
    }

    // ============================================================
    // RENDER HELPERS
    // ============================================================
    function e(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function getTodayBlitzId() {
      const blitzKeys = Object.keys(blitzes);
      const dayIndex = Math.floor(Date.now() / 86400000) % blitzKeys.length;
      return blitzKeys[dayIndex];
    }

    function renderHome() {
      const todayBlitzId = getTodayBlitzId();
      const todayBlitz = blitzes[todayBlitzId];
      return `
        <div>
