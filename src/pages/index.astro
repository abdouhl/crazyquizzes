---
import catsData    from '../data/categories.json';
import cardsData   from '../data/cards.json';
import quizzesData from '../data/quizzes.json';
import blitzesData from '../data/blitzes.json';

const totalQuizzes = (cardsData as any[]).length;
const totalBlitzes = (cardsData as any[]).filter((c: any) => c.type === 'blitz').length;
const totalPersonality = (cardsData as any[]).filter((c: any) => c.type === 'personality').length;

const homeJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://crazyquizzes.com/#organization',
      name: 'CrazyQuizzes',
      url: 'https://crazyquizzes.com',
      logo: {
        '@type': 'ImageObject',
        url: 'https://crazyquizzes.com/og-default.png',
        width: 1200,
        height: 630,
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://crazyquizzes.com/#website',
      url: 'https://crazyquizzes.com/',
      name: 'CrazyQuizzes',
      description: 'Free personality quizzes, trivia blitz games, and emoji challenges online.',
      publisher: { '@id': 'https://crazyquizzes.com/#organization' },
    },
    {
      '@type': 'ItemList',
      name: 'Quizzes & Trivia Blitzes',
      url: 'https://crazyquizzes.com/',
      numberOfItems: (cardsData as any[]).length,
      itemListElement: (cardsData as any[]).slice(0, 10).map((card: any, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: card.title,
        url: `https://crazyquizzes.com/${card.type === 'blitz' ? 'blitz' : card.type === 'compare' ? 'compare' : 'quiz'}/${card.id}`,
      })),
    },
  ],
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CrazyQuizzes — Free Personality Quizzes &amp; Trivia Games Online</title>
  <meta name="description" content="Free personality quizzes, trivia blitz games, and emoji challenges. Discover your type, test your knowledge, and share results with friends." />
  <link rel="canonical" href="https://crazyquizzes.com/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CrazyQuizzes" />
  <meta property="og:url" content="https://crazyquizzes.com/" />
  <meta property="og:title" content="CrazyQuizzes — Free Personality Quizzes &amp; Trivia Games Online" />
  <meta property="og:description" content="Free personality quizzes, trivia blitz games, and emoji challenges. Discover your type, test your knowledge, and share results with friends." />
  <meta property="og:image" content="https://crazyquizzes.com/og-default.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="CrazyQuizzes — Free Personality Quizzes &amp; Trivia Games Online" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="CrazyQuizzes — Free Personality Quizzes &amp; Trivia Games Online" />
  <meta name="twitter:description" content="Free personality quizzes, trivia blitz games, and emoji challenges. Discover your type, test your knowledge, and share results with friends." />
  <meta name="twitter:image" content="https://crazyquizzes.com/og-default.png" />
  <meta name="twitter:image:alt" content="CrazyQuizzes — Free Personality Quizzes &amp; Trivia Games Online" />
  <meta name="theme-color" content="#6c3bff" />
  <script type="application/ld+json" set:html={homeJsonLd} />
  <!-- Google AdSense Auto Ads -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3610150616518651" crossorigin="anonymous"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bungee&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    @keyframes cq-marquee  { from { transform: translateX(0); }    to   { transform: translateX(-50%); } }
    @keyframes cq-blink    { 0%,55%{opacity:1}   56%,100%{opacity:0} }
    @keyframes cq-spin     { to { transform: rotate(360deg); } }
    @keyframes cq-wiggle   { 0%,100%{transform:rotate(-4deg)} 50%{transform:rotate(4deg)} }
    @keyframes cq-pop      { 0%{transform:scale(.6);opacity:0} 65%{transform:scale(1.1)} 100%{transform:scale(1);opacity:1} }
    @keyframes cq-fadein   { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    @keyframes cq-slideup  { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

    body {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      color: #1a1430;
      background-color: #f3eeff;
      background-image: linear-gradient(rgba(108,59,255,.08) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(108,59,255,.08) 1px, transparent 1px);
      background-size: 28px 28px;
      overflow-x: hidden;
    }

    /* ── MARQUEE ── */
    .marquee-bar { background:#1a1430; border-bottom:3px solid #1a1430; overflow:hidden; white-space:nowrap; padding:9px 0; }
    .marquee-track { display:inline-block; white-space:nowrap; animation:cq-marquee 22s linear infinite; font-family:'Bungee',cursive; font-size:13px; letter-spacing:.04em; color:#3bffd2; }
    .marquee-track span { padding:0 6px; }

    /* ── HEADER ── */
    header { position:sticky; top:0; z-index:50; background:#fffdf7; border-bottom:3px solid #1a1430; box-shadow:0 4px 0 rgba(26,20,48,.12); }
    .header-inner { max-width:1140px; margin:0 auto; padding:12px 22px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
    .logo { display:flex; align-items:center; gap:10px; cursor:pointer; text-decoration:none; }
    .logo-star { font-family:'Bungee',cursive; color:#6c3bff; display:inline-block; animation:cq-spin 7s linear infinite; font-size:22px; }
    .logo-text { font-family:'Bungee',cursive; font-size:clamp(18px,3vw,24px); letter-spacing:.01em; }
    .logo-text .crazy { color:#6c3bff; }
    .logo-text .quizzes { color:#1a1430; }
    nav { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .nav-btn { cursor:pointer; text-decoration:none; color:#1a1430; border:2px solid #1a1430; padding:7px 12px; box-shadow:3px 3px 0 #1a1430; transition:transform .1s,box-shadow .1s; background:#3bffd2; font-family:'Bungee',cursive; font-size:11px; display:inline-block; }
    .nav-btn:hover { transform:translate(-1px,-1px); box-shadow:4px 4px 0 #1a1430; }
    .nav-btn.yellow { background:#ffd23f; }
    .nav-btn.pink { background:#ff3b9a; color:#fff; }
    .nav-plain { cursor:pointer; text-decoration:none; color:#1a1430; padding:7px 6px; opacity:.7; font-family:'Bungee',cursive; font-size:11px; }

    #app { max-width:1140px; margin:0 auto; padding:0 22px; }

    /* ── HERO ── */
    .hero { position:relative; padding:48px 0 30px; }
    .hero-sticker { position:absolute; top:18px; right:6px; font-family:'Bungee',cursive; font-size:11px; background:#ffd23f; border:3px solid #1a1430; box-shadow:4px 4px 0 #1a1430; padding:10px 12px; transform:rotate(7deg); animation:cq-wiggle 2.6s ease-in-out infinite; text-align:center; line-height:1.3; max-width:140px; }
    .hero-badge { display:inline-block; font-family:'Bungee',cursive; font-size:12px; background:#1a1430; color:#3bffd2; padding:7px 12px; border:3px solid #1a1430; box-shadow:4px 4px 0 #6c3bff; margin-bottom:18px; }
    .hero h1 { font-family:'Bungee',cursive; font-size:clamp(36px,7vw,84px); line-height:.96; margin:0 0 16px; max-width:14ch; text-shadow:5px 5px 0 #3bffd2; }
    .hero h1 .purple { color:#6c3bff; text-shadow:5px 5px 0 #ff3b9a; }
    .hero p { font-size:clamp(15px,2vw,19px); max-width:46ch; font-weight:500; line-height:1.45; margin:0 0 22px; }
    .hero-btns { display:flex; gap:14px; flex-wrap:wrap; align-items:center; margin-bottom:20px; }
    .btn-primary { font-family:'Bungee',cursive; font-size:clamp(13px,1.8vw,16px); color:#fff; background:#6c3bff; border:3px solid #1a1430; box-shadow:6px 6px 0 #1a1430; padding:15px 24px; cursor:pointer; transition:transform .1s,box-shadow .1s; text-decoration:none; display:inline-block; }
    .btn-primary:hover { transform:translate(-2px,-2px); box-shadow:8px 8px 0 #1a1430; }
    .btn-secondary { font-family:'Bungee',cursive; font-size:clamp(13px,1.8vw,16px); color:#1a1430; background:#fffdf7; border:3px solid #1a1430; box-shadow:6px 6px 0 #1a1430; padding:15px 24px; cursor:pointer; transition:transform .1s,box-shadow .1s; text-decoration:none; display:inline-block; }
    .btn-secondary:hover { transform:translate(-2px,-2px); box-shadow:8px 8px 0 #3bffd2; }

    /* Hero stats strip */
    .hero-stats { display:flex; gap:8px; flex-wrap:wrap; }
    .hero-stat { font-family:'Bungee',cursive; font-size:10px; background:#fffdf7; border:2px solid #1a1430; box-shadow:2px 2px 0 #6c3bff; padding:6px 10px; white-space:nowrap; }

    /* ── SEARCH ── */
    .search-wrap { margin:22px 0 20px; }
    .search-box { display:flex; align-items:center; gap:10px; background:#fff; border:3px solid #1a1430; box-shadow:5px 5px 0 #1a1430; padding:11px 15px; transition:box-shadow .1s; }
    .search-box:focus-within { box-shadow:5px 5px 0 #6c3bff; }
    .search-icon { font-size:17px; flex:none; opacity:.5; }
    .search-input { flex:1; min-width:0; background:none; border:none; outline:none; font-family:'Bungee',cursive; font-size:13px; color:#1a1430; }
    .search-input::placeholder { color:#a79fc0; font-size:12px; }
    .search-clear { background:none; border:none; cursor:pointer; font-family:'Bungee',cursive; font-size:12px; color:#ff3b9a; padding:0; flex:none; display:none; }
    .search-count { font-family:'Bungee',cursive; font-size:11px; color:#6c3bff; margin:0 0 14px; min-height:18px; }

    /* ── CATEGORY CHIPS ── */
    .cat-chips { padding:6px 0 26px; display:flex; gap:8px; flex-wrap:wrap; }
    .chip { font-family:'Bungee',cursive; font-size:11px; border:2px solid #1a1430; box-shadow:3px 3px 0 #1a1430; padding:7px 12px; cursor:pointer; transition:transform .1s,box-shadow .1s; user-select:none; }
    .chip:hover { transform:translateY(-2px); box-shadow:3px 5px 0 #1a1430; }
    .chip--active { transform:translate(-2px,-2px) !important; box-shadow:5px 5px 0 #6c3bff !important; outline:3px solid #6c3bff; outline-offset:1px; }

    /* ── DAILY BLITZ BANNER ── */
    .blitz-banner { position:relative; overflow:hidden; background:#1a1430; border:3px solid #1a1430; box-shadow:9px 9px 0 #6c3bff; cursor:pointer; padding:30px 28px; display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; transition:transform .12s,box-shadow .12s; margin-bottom:32px; text-decoration:none; }
    .blitz-banner:hover { transform:translate(-3px,-3px); box-shadow:12px 12px 0 #6c3bff; }
    .blitz-bg-icon { position:absolute; top:-12px; right:-8px; font-size:120px; opacity:.08; line-height:1; pointer-events:none; }
    .blitz-eyebrow { font-family:'Bungee',cursive; font-size:11px; color:#3bffd2; margin-bottom:12px; }
    .blitz-banner h2 { font-family:'Bungee',cursive; font-size:clamp(26px,5vw,48px); line-height:.98; color:#fff; margin:0 0 10px; }
    .blitz-banner h2 .yellow { color:#ffd23f; }
    .blitz-banner p { color:#b3a9d6; font-weight:500; font-size:15px; line-height:1.45; margin:0; }
    .blitz-right { display:flex; flex-direction:column; gap:14px; align-items:flex-start; }
    .blitz-emojis { display:flex; gap:10px; font-size:34px; line-height:1; animation:cq-wiggle 2.6s ease-in-out infinite; }
    .blitz-play-btn { font-family:'Bungee',cursive; font-size:14px; color:#1a1430; background:#3bffd2; border:3px solid #3bffd2; box-shadow:5px 5px 0 #ff3b9a; padding:13px 20px; }

    /* ── FEATURED ROW ── */
    .featured-wrap { margin-bottom:32px; animation:cq-fadein .3s ease both; }
    .featured-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:8px; }
    .featured-hdr h2 { font-family:'Bungee',cursive; font-size:clamp(18px,3vw,28px); margin:0; }
    .featured-swipe { font-family:'Bungee',cursive; font-size:10px; color:#6c3bff; opacity:.7; }
    .featured-scroll { display:flex; gap:14px; overflow-x:auto; padding-bottom:10px; scroll-snap-type:x mandatory; scrollbar-width:none; -ms-overflow-style:none; }
    .featured-scroll::-webkit-scrollbar { display:none; }
    .featured-card { flex:none; width:185px; scroll-snap-align:start; background:#fff; border:3px solid #1a1430; box-shadow:5px 5px 0 #1a1430; text-decoration:none; color:inherit; overflow:hidden; display:block; transition:transform .12s,box-shadow .12s; }
    .featured-card:hover { transform:translate(-2px,-2px); box-shadow:7px 7px 0 #6c3bff; }
    .featured-cover { height:105px; display:flex; align-items:center; justify-content:center; font-size:40px; border-bottom:3px solid #1a1430; position:relative; overflow:hidden; }
    .featured-badge { position:absolute; top:6px; right:6px; font-family:'Bungee',cursive; font-size:9px; border:2px solid #1a1430; box-shadow:2px 2px 0 #1a1430; padding:3px 6px; transform:rotate(4deg); }
    .featured-body { padding:10px 12px 13px; }
    .featured-cat { font-family:'Bungee',cursive; font-size:9px; color:#6c3bff; margin-bottom:4px; }
    .featured-title { font-weight:700; font-size:13px; line-height:1.2; }

    /* ── QUIZ GRID ── */
    .section-hdr { display:flex; align-items:baseline; gap:12px; margin-bottom:18px; flex-wrap:wrap; }
    .section-hdr h2 { font-family:'Bungee',cursive; font-size:clamp(20px,3vw,32px); margin:0; }
    .live-badge { font-weight:600; font-size:13px; background:#ff3b9a; color:#fff; border:2px solid #1a1430; padding:3px 9px; animation:cq-blink 1.4s steps(1) infinite; }

    .quiz-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(270px,1fr)); gap:20px; padding-bottom:60px; }
    .quiz-card { background:#fff; border:3px solid #1a1430; box-shadow:6px 6px 0 #1a1430; cursor:pointer; transition:transform .12s,box-shadow .12s; overflow:hidden; text-decoration:none; color:inherit; display:block; }
    .quiz-card:hover { transform:translate(-3px,-3px); box-shadow:9px 9px 0 #6c3bff; }

    .quiz-card-cover { height:178px; border-bottom:3px solid #1a1430; position:relative; display:flex; align-items:center; justify-content:center; overflow:hidden; }
    .quiz-card-cover-emoji { font-size:58px; line-height:1; filter:drop-shadow(0 4px 14px rgba(0,0,0,.45)); user-select:none; letter-spacing:.05em; position:relative; z-index:1; }
    .quiz-card-cover-img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:top center; }
    .quiz-card-play-overlay { position:absolute; inset:0; background:rgba(108,59,255,.84); color:#3bffd2; font-family:'Bungee',cursive; font-size:17px; letter-spacing:.08em; display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity .15s; z-index:2; }
    .quiz-card:hover .quiz-card-play-overlay { opacity:1; }

    .quiz-card-badge { position:absolute; top:10px; right:10px; font-family:'Bungee',cursive; font-size:10px; border:2px solid #1a1430; box-shadow:2px 2px 0 #1a1430; padding:4px 8px; transform:rotate(5deg); z-index:3; }
    .quiz-card-body { padding:15px 16px 18px; }
    .quiz-card-cat { font-family:'Bungee',cursive; font-size:10px; color:#6c3bff; margin-bottom:7px; }
    .quiz-card-title { font-weight:700; font-size:18px; line-height:1.18; margin:0 0 12px; }
    .quiz-card-footer { display:flex; align-items:center; justify-content:space-between; gap:8px; }
    .quiz-card-takes { font-size:12px; font-weight:600; color:#6b6285; }
    .quiz-card-play { font-family:'Bungee',cursive; font-size:10px; color:#fff; background:#1a1430; padding:5px 10px; }

    /* ── NO RESULTS ── */
    .no-results { display:none; grid-column:1/-1; padding:60px 0; text-align:center; animation:cq-fadein .2s ease; }
    .no-results-icon { font-size:52px; margin-bottom:14px; }
    .no-results-title { font-family:'Bungee',cursive; font-size:22px; color:#6c3bff; margin-bottom:8px; }
    .no-results-text { font-weight:500; color:#6b6285; margin:0 0 20px; font-size:15px; }
    .no-results-btn { font-family:'Bungee',cursive; font-size:12px; background:#6c3bff; color:#fff; border:2px solid #1a1430; box-shadow:3px 3px 0 #1a1430; padding:10px 16px; cursor:pointer; }

    /* ── FOOTER ── */
    footer { margin:0 -22px; border-top:3px solid #1a1430; background:#1a1430; color:#f3eeff; padding:40px 22px 30px; }
    .footer-inner { max-width:1140px; margin:0 auto; display:flex; gap:30px; flex-wrap:wrap; justify-content:space-between; align-items:flex-start; }
    .footer-brand { max-width:300px; }
    .footer-logo { font-family:'Bungee',cursive; font-size:22px; margin-bottom:10px; }
    .footer-logo .crazy { color:#3bffd2; }
    .footer-logo .quizzes { color:#fff; }
    .footer-desc { font-size:13px; line-height:1.5; color:#b3a9d6; margin:0 0 14px; }
    .footer-tagline { font:600 10px/1 'Courier New',monospace; color:#3bffd2; letter-spacing:.1em; }
    .footer-stats { margin-top:18px; display:flex; gap:8px; flex-wrap:wrap; }
    .footer-stat-chip { font-family:'Bungee',cursive; font-size:10px; border:1px solid #3a3358; color:#b3a9d6; padding:5px 8px; }
    .footer-sitemap { font-family:'Bungee',cursive; font-size:11px; display:flex; flex-direction:column; gap:10px; }
    .footer-sitemap .label { color:#ff3b9a; }
    .footer-sitemap a { color:#fff; text-decoration:none; cursor:pointer; }
    .footer-sitemap a:hover { color:#3bffd2; }
    .footer-bottom { max-width:1140px; margin:26px auto 0; border-top:1px solid #3a3358; padding-top:16px; font-size:12px; color:#8479a8; display:flex; gap:14px; flex-wrap:wrap; justify-content:space-between; }

    /* ── TOAST ── */
    .toast { position:fixed; left:50%; bottom:26px; transform:translateX(-50%); z-index:80; background:#1a1430; color:#3bffd2; border:3px solid #3bffd2; box-shadow:5px 5px 0 #6c3bff; font-family:'Bungee',cursive; font-size:12px; padding:13px 18px; animation:cq-pop .3s ease both; white-space:nowrap; }

    /* ── TOUCH ── */
    button, a, .chip { touch-action:manipulation; -webkit-tap-highlight-color:transparent; }

    /* ── MOBILE ── */
    @media (max-width: 640px) {
      .header-inner { padding:9px 14px; gap:8px; }
      .logo-star { font-size:18px; }
      .logo-text { font-size:16px; }
      .nav-btn { font-size:10px; padding:6px 9px; box-shadow:2px 2px 0 #1a1430; }
      .nav-plain { display:none; }

      #app { padding:0 14px; }

      .hero { padding:24px 0 16px; }
      .hero-sticker { display:none; }
      .hero h1 { font-size:clamp(30px,9.5vw,52px); margin-bottom:12px; text-shadow:3px 3px 0 #3bffd2; }
      .hero h1 .purple { text-shadow:3px 3px 0 #ff3b9a; }
      .hero p { font-size:14px; margin-bottom:16px; }
      .btn-primary, .btn-secondary { font-size:13px; padding:11px 16px; box-shadow:4px 4px 0 #1a1430; }
      .hero-stats { gap:5px; }
      .hero-stat { font-size:9px; padding:5px 8px; }

      .search-wrap { margin:16px 0 14px; }
      .search-box { padding:9px 12px; }
      .search-input { font-size:11px; }

      .cat-chips { gap:6px; padding:4px 0 16px; }
      .chip { font-size:10px; padding:6px 9px; box-shadow:2px 2px 0 #1a1430; }

      .blitz-banner { padding:18px 16px; gap:14px; box-shadow:6px 6px 0 #6c3bff; margin-bottom:20px; }
      .blitz-eyebrow { font-size:10px; margin-bottom:7px; }
      .blitz-banner h2 { font-size:clamp(20px,6vw,32px); margin-bottom:7px; }
      .blitz-banner p { font-size:13px; }
      .blitz-right { display:none; }
      .blitz-bg-icon { font-size:80px; }
      .blitz-play-btn { font-size:12px; padding:10px 14px; box-shadow:3px 3px 0 #ff3b9a; }

      .featured-wrap { margin-bottom:20px; }
      .featured-card { width:155px; }
      .featured-cover { height:88px; font-size:32px; }
      .featured-title { font-size:12px; }

      .quiz-grid { grid-template-columns:1fr; gap:13px; padding-bottom:40px; }
      .quiz-card-cover { height:135px; }
      .quiz-card-cover-emoji { font-size:46px; }
      .quiz-card-body { padding:12px 13px 14px; }
      .quiz-card-title { font-size:16px; margin-bottom:10px; }

      .section-hdr { margin-bottom:12px; }
      .section-hdr h2 { font-size:clamp(17px,5vw,24px); }

      footer { margin:0 -14px; padding:28px 14px 22px; }
      .footer-inner { gap:18px; }
    }

    @media (min-width:480px) and (max-width:640px) {
      .quiz-grid { grid-template-columns:1fr 1fr; gap:11px; }
      .quiz-card-cover { height:115px; }
    }
  </style>
</head>
<body>

  <!-- SCROLLING MARQUEE -->
  <div class="marquee-bar">
    <div class="marquee-track">
      <span>✦ NEW QUIZZES EVERY DAMN DAY</span><span style="color:#ff3b9a;">✦ 2.3M QUIZZES TAKEN THIS WEEK</span><span style="color:#ffd23f;">✦ NO LOGIN. NO RULES. NO MERCY</span><span style="color:#3bffd2;">✦ 100% SCIENTIFICALLY INACCURATE</span><span>✦ NEW QUIZZES EVERY DAMN DAY</span><span style="color:#ff3b9a;">✦ 2.3M QUIZZES TAKEN THIS WEEK</span><span style="color:#ffd23f;">✦ NO LOGIN. NO RULES. NO MERCY</span><span style="color:#3bffd2;">✦ 100% SCIENTIFICALLY INACCURATE</span>
    </div>
  </div>

  <!-- HEADER -->
  <header>
    <div class="header-inner">
      <button class="logo" id="logo-btn" aria-label="Go home">
        <span class="logo-star">✦</span>
        <span class="logo-text"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></span>
      </button>
      <nav>
        <button id="nav-quizzes" class="nav-btn">QUIZZES</button>
        <a id="nav-blitz" class="nav-btn yellow" href="/">⚡ DAILY BLITZ</a>
        <button id="nav-random" class="nav-btn pink">🎲 RANDOM</button>
        <button id="nav-categories" class="nav-plain" style="background:none;border:none;cursor:pointer;">CATEGORIES</button>
        <a href="/about" class="nav-plain">ABOUT</a>
      </nav>
    </div>
  </header>

  <!-- MAIN APP -->
  <div id="app"></div>

  <!-- TOAST -->
  <div id="toast" class="toast" style="display:none;">✓ LINK COPIED — GO RUIN SOMEONE'S DAY</div>

  <script define:vars={{ cats: catsData, cards: cardsData, quizzes: quizzesData, blitzes: blitzesData, srvTotal: totalQuizzes, srvBlitz: totalBlitzes, srvPersonality: totalPersonality }}>

    // ── STATE ──────────────────────────────────────────────────────────────────
    let state = {
      view: 'home',
      activeCat: 'ALL',
      searchQuery: '',
    };

    function setState(u) { state = { ...state, ...u }; render(); }

    // ── CATEGORY COUNTS ────────────────────────────────────────────────────────
    const catCounts = {};
    cards.forEach(c => (c.categories || []).forEach(cat => { catCounts[cat] = (catCounts[cat] || 0) + 1; }));

    // ── DAILY BLITZ ────────────────────────────────────────────────────────────
    function getTodayBlitzId() {
      const keys = Object.keys(blitzes);
      return keys[Math.floor(Date.now() / 86400000) % keys.length];
    }

    // ── LIVE SEARCH FILTER ─────────────────────────────────────────────────────
    function applyFilters() {
      const q = (state.searchQuery || '').toLowerCase().trim();
      let visible = 0;
      document.querySelectorAll('.quiz-card[data-searchable]').forEach(card => {
        const show = !q || card.dataset.searchable.toLowerCase().includes(q);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      const countEl = document.getElementById('search-count');
      if (countEl) countEl.textContent = q ? `${visible} RESULT${visible !== 1 ? 'S' : ''} FOR "${q.toUpperCase()}"` : '';
      const noEl = document.getElementById('no-results');
      if (noEl) noEl.style.display = (!q || visible > 0) ? 'none' : '';
      const clearBtn = document.getElementById('search-clear-btn');
      if (clearBtn) clearBtn.style.display = q ? '' : 'none';
    }

    // ── ACTIONS ────────────────────────────────────────────────────────────────
    function goHome() { setState({ view: 'home', searchQuery: '' }); }
    function filterCat(label) {
      if (state.view !== 'home') { setState({ view: 'home', activeCat: label }); return; }
      setState({ activeCat: label });
      document.getElementById('cat-chips-section')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    function openCategories() {
      if (state.view !== 'home') { setState({ view: 'home', activeCat: 'ALL' }); return; }
      document.getElementById('cat-chips-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    function openRandom() {
      const card = cards[Math.floor(Math.random() * cards.length)];
      const rPath = card.type === 'blitz' ? 'blitz' : card.type === 'compare' ? 'compare' : 'quiz';
      window.location.href = `/${rPath}/${card.id}`;
    }
    function doClearSearch() {
      state.searchQuery = '';
      const si = document.getElementById('search-input');
      if (si) { si.value = ''; si.focus(); }
      applyFilters();
    }
    function showToast(msg) {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg;
      t.style.display = 'block';
      clearTimeout(showToast._tid);
      showToast._tid = setTimeout(() => { t.style.display = 'none'; }, 2800);
    }

    function e(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── RENDER HOME ────────────────────────────────────────────────────────────
    function renderHome() {
      const todayBlitzId = getTodayBlitzId();
      const todayBlitz = blitzes[todayBlitzId];
      const filtered = cards.filter(c => c.categories.includes(state.activeCat));
      const featuredCards = cards.filter(c => c.type === 'personality');

      return `
        <div style="animation:cq-fadein .18s ease both;">

          <!-- HERO -->
          <section class="hero">
            <div class="hero-sticker">100% SCIENTIFICALLY INACCURATE</div>
            <div class="hero-badge">★ THE INTERNET'S DUMBEST QUIZ SITE ★</div>
            <h1>WHAT KIND OF<br><span class="purple">CHAOS</span> ARE YOU?</h1>
            <p>Take a quiz. Get judged by an algorithm with zero credentials. Send the results to the group chat. Repeat until 3am.</p>
            <div class="hero-btns">
              <button class="btn-primary" data-action="random">🎲 SPIN A RANDOM QUIZ</button>
              <button class="btn-secondary" data-action="browse">↓ BROWSE ALL</button>
            </div>
            <div class="hero-stats">
              <span class="hero-stat">📚 ${srvTotal} QUIZZES</span>
              <span class="hero-stat">⚡ ${srvBlitz} BLITZES</span>
              <span class="hero-stat">🎭 ${srvPersonality} PERSONALITY</span>
              <span class="hero-stat">✨ FREE FOREVER</span>
            </div>
          </section>

          <!-- SEARCH -->
          <div class="search-wrap">
            <div class="search-box">
              <span class="search-icon">🔍</span>
              <input class="search-input" id="search-input"
                     placeholder="SEARCH ${srvTotal} QUIZZES..."
                     autocomplete="off" autocorrect="off" spellcheck="false"
                     value="${e(state.searchQuery)}" />
              <button class="search-clear" id="search-clear-btn" data-action="search-clear" aria-label="Clear">✕</button>
            </div>
          </div>
          <div class="search-count" id="search-count"></div>

          <!-- CATEGORY CHIPS -->
          <section class="cat-chips" id="cat-chips-section">
            ${cats.map(cat => `
              <span class="chip${state.activeCat === cat.label ? ' chip--active' : ''}"
                style="background:${e(cat.color)};color:${e(cat.ink)};"
                data-action="filter" data-cat="${e(cat.label)}"
                title="${catCounts[cat.label] || 0} quizzes">
                ${e(cat.label)}${cat.label !== 'ALL' ? ` <span style="opacity:.65;font-size:9px;">(${catCounts[cat.label] || 0})</span>` : ''}
              </span>
            `).join('')}
          </section>

          <!-- DAILY BLITZ BANNER -->
          <a href="/blitz/${e(todayBlitzId)}" class="blitz-banner">
            <div class="blitz-bg-icon">⚡</div>
            <div style="position:relative;max-width:48ch;">
              <div class="blitz-eyebrow">⚡ NEW EVERY DAY · PLAY-ALONG · BEAT THE CLOCK</div>
              <h2>TODAY'S <span class="yellow">BLITZ</span></h2>
              <p>${e(todayBlitz.title)} — ${todayBlitz.questions.length} questions, 10 seconds each. How fast is your brain?</p>
            </div>
            <div class="blitz-right">
              <div class="blitz-emojis">🎬 🚩 ✅ 🧠</div>
              <span class="blitz-play-btn">▶ PLAY THE BLITZ</span>
            </div>
          </a>

          <!-- PERSONALITY PICKS ROW -->
          ${featuredCards.length > 0 ? `
          <section class="featured-wrap">
            <div class="featured-hdr">
              <h2>🎭 PERSONALITY PICKS</h2>
              <span class="featured-swipe">SWIPE TO EXPLORE →</span>
            </div>
            <div class="featured-scroll">
              ${featuredCards.map(card => `
                <a href="/quiz/${e(card.id)}" class="featured-card">
                  <div class="featured-cover" style="background:${e(card.coverBg)};">
                    <span>${e(card.coverEmoji)}</span>
                    <span class="featured-badge" style="background:${e(card.badgeColor)};color:${e(card.badgeInk)};">${e(card.badge)}</span>
                  </div>
                  <div class="featured-body">
                    <div class="featured-cat">${e(card.cat)}</div>
                    <div class="featured-title">${e(card.title)}</div>
                  </div>
                </a>
              `).join('')}
            </div>
          </section>` : ''}

          <!-- QUIZ GRID -->
          <section style="padding:4px 0 0;">
            <div class="section-hdr">
              <h2>🔥 ${state.activeCat === 'ALL' ? 'ALL QUIZZES' : state.activeCat}</h2>
              <span class="live-badge">LIVE</span>
            </div>
            <div class="quiz-grid">
              ${filtered.map(card => `
                <a href="${card.type === 'blitz' ? '/blitz/' : card.type === 'compare' ? '/compare/' : '/quiz/'}${e(card.id)}"
                   class="quiz-card"
                   data-searchable="${e((card.title + ' ' + card.cat + ' ' + (card.categories || []).join(' ')).toLowerCase())}"
                   data-cats="${e((card.categories || []).join(','))}">
                  <div class="quiz-card-cover" style="background:${e(card.coverBg)};">
                    ${card.coverImg ? `<img class="quiz-card-cover-img" src="${e(card.coverImg)}" alt="${e(card.title)}" loading="lazy" referrerpolicy="no-referrer">` : `<span class="quiz-card-cover-emoji">${e(card.coverEmoji || '')}</span>`}
                    <div class="quiz-card-play-overlay">▶ PLAY</div>
                    <span class="quiz-card-badge" style="background:${e(card.badgeColor)};color:${e(card.badgeInk)};">${e(card.badge)}</span>
                  </div>
                  <div class="quiz-card-body">
                    <div class="quiz-card-cat">${e(card.cat)}</div>
                    <h3 class="quiz-card-title">${e(card.title)}</h3>
                    <div class="quiz-card-footer">
                      <span class="quiz-card-takes">👁 ${e(card.takes)} took this</span>
                      <span class="quiz-card-play">PLAY ▸</span>
                    </div>
                  </div>
                </a>
              `).join('')}

              <!-- NO RESULTS STATE -->
              <div class="no-results" id="no-results">
                <div class="no-results-icon">🔍</div>
                <div class="no-results-title">NO QUIZZES FOUND</div>
                <p class="no-results-text">Try a different search or clear the filter.</p>
                <button class="no-results-btn" data-action="search-clear">CLEAR SEARCH</button>
              </div>
            </div>
          </section>

          <!-- FOOTER -->
          <footer>
            <div class="footer-inner">
              <div class="footer-brand">
                <div class="footer-logo"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></div>
                <p class="footer-desc">Diagnosing your personality with snacks since right now. Results may be used against you in the group chat.</p>
                <div class="footer-tagline">★ BEST VIEWED IN NETSCAPE NAVIGATOR 4.0 ★</div>
                <div class="footer-stats">
                  <span class="footer-stat-chip">📚 ${srvTotal} QUIZZES</span>
                  <span class="footer-stat-chip">⚡ ${srvBlitz} BLITZES</span>
                  <span class="footer-stat-chip">✨ FREE</span>
                </div>
                <a href="https://www.pinterest.com/crazyquizzes/" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;margin-top:14px;background:#e60023;color:#fff;font-family:'Bungee',cursive;font-size:11px;padding:8px 14px;border:2px solid #1a1430;box-shadow:3px 3px 0 #1a1430;text-decoration:none;"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>PINTEREST</a>
              </div>
              <div class="footer-sitemap">
                <span class="label">QUIZZES</span>
                <a data-action="home" style="cursor:pointer;">All Quizzes</a>
                <a href="/personality-quizzes">Personality Quizzes</a>
                <a href="/trivia-quizzes">Trivia Blitzes</a>
                <a data-action="random" style="cursor:pointer;">Random Quiz</a>
                <span class="label" style="margin-top:8px;">PERSONALITY</span>
                <a href="/quiz/y2k-snack">Which Y2K Snack Are You?</a>
                <a href="/quiz/kpop-which-group">Which K-pop Group Are You?</a>
                <span class="label" style="margin-top:8px;">COMPANY</span>
                <a href="/about">About</a>
                <a href="/contact">Contact</a>
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Use</a>
              </div>
            </div>
            <div class="footer-bottom">
              <span>© 2026 CrazyQuizzes.com — made with ♥ and zero focus groups</span>
              <span>crazyquizzes.com</span>
            </div>
          </footer>
        </div>
      `;
    }

    // ── RENDER ─────────────────────────────────────────────────────────────────
    function render() {
      const app = document.getElementById('app');
      app.innerHTML = renderHome();
      window.scrollTo({ top: 0, behavior: 'instant' });

      // Re-apply search after DOM rebuild
      const si = document.getElementById('search-input');
      if (si) {
        si.value = state.searchQuery || '';
        if (state.searchQuery) applyFilters();
      }
    }

    // ── EVENT DELEGATION ───────────────────────────────────────────────────────
    document.addEventListener('click', (ev) => {
      // Search clear button
      const clearBtn = ev.target.closest('#search-clear-btn, [data-action="search-clear"]');
      if (clearBtn) { doClearSearch(); return; }

      const el = ev.target.closest('[data-action]');
      if (!el) return;
      switch (el.dataset.action) {
        case 'home':       goHome(); break;
        case 'random':     openRandom(); break;
        case 'browse':     document.getElementById('cat-chips-section')?.scrollIntoView({ behavior: 'smooth' }); break;
        case 'filter':     filterCat(el.dataset.cat); break;
        case 'categories': openCategories(); break;
      }
    });

    // Live search (no re-render)
    document.addEventListener('input', (ev) => {
      if (ev.target.id !== 'search-input') return;
      state.searchQuery = ev.target.value;
      applyFilters();
    });

    // ── HEADER BUTTONS ─────────────────────────────────────────────────────────
    document.getElementById('logo-btn').addEventListener('click', goHome);
    document.getElementById('nav-quizzes').addEventListener('click', goHome);
    document.getElementById('nav-blitz').href = `/blitz/${getTodayBlitzId()}`;
    document.getElementById('nav-random').addEventListener('click', openRandom);
    document.getElementById('nav-categories').addEventListener('click', openCategories);

    // Initial render
    render();
  </script>
</body>
</html>
