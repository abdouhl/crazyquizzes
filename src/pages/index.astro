                      <div class="quiz-card-cat">${e(card.cat)}</div>
                      <h3 class="quiz-card-title">${e(card.title)}</h3>
                      <div class="quiz-card-footer">
                        <span class="quiz-card-takes">👁 ${e(card.takes)} took this</span>
                        <span class="quiz-card-play">PLAY ▸</span>
                      </div>
                    </div>
                  </a>
                `).join('');
              })()}
            </div>
          </section>

          <!-- FOOTER -->
          <footer>
            <div class="footer-inner">
              <div class="footer-brand">
                <div class="footer-logo"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></div>
                <p class="footer-desc">Diagnosing your personality with snacks since right now. Results may be used against you in the group chat.</p>
                <div class="footer-tagline">★ BEST VIEWED IN NETSCAPE NAVIGATOR 4.0 ★</div>
              </div>
              <div>
                <div class="footer-counter-label">VISITOR COUNT</div>
                <div class="counter-digits">
                  ${hitDigits.map(d => `<span class="counter-digit">${e(d)}</span>`).join('')}
                </div>
                <div class="footer-wip">UNDER-CONSTRUCTION.GIF</div>
              </div>
              <div class="footer-sitemap">
                <span class="label">QUIZZES</span>
                <a data-action="home" style="cursor:pointer;">All Quizzes</a>
                <a data-action="random" style="cursor:pointer;">Random Quiz</a>
                <span class="label" style="margin-top:8px;">COMPANY</span>
                <a href="/about">About</a>
                <a href="/contact">Contact</a>
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Use</a>
              </div>
            </div>
            <div class="footer-bottom">
              <span>© 2026 CrazyQuizzes.com — made with ♥ and zero focus groups</span>
              <span>crazyquizzes.com</span>
            </div>
          </footer>
        </div>
      `;
    }

    function renderIntro() {
      const quiz = quizzes[state.activeQuizId];
      return `
        <div class="view-intro">
          <button class="back-link" data-action="home">← BACK TO QUIZZES</button>
          <div class="intro-card">
            <div class="intro-cover">
              <span class="intro-cover-label">${e(quiz.cover)}</span>
              <span class="intro-viral">🔥 VIRAL</span>
            </div>
            <div class="intro-body">
              <div class="intro-cat">${e(quiz.cat)}</div>
              <h1>${e(quiz.title)}</h1>
              <p>${e(quiz.desc)}</p>
              <div class="intro-meta">
                <span class="meta-chip" style="background:#3bffd2;">${e(quiz.qcount)} QUESTIONS</span>
                <span class="meta-chip" style="background:#ffd23f;">≈ ${e(quiz.minutes)} MIN</span>
                <span class="meta-chip" style="background:#fff;">👁 ${e(quiz.takes)} TOOK THIS</span>
              </div>
              <button class="btn-start" data-action="start">START THE CHAOS →</button>
            </div>
          </div>
        </div>
      `;
    }

    function renderQuestion() {
      const quiz = quizzes[state.activeQuizId];
      const total = quiz.questions.length;
      const num = state.qIndex + 1;
      const q = quiz.questions[state.qIndex];
      const pct = Math.round((num / total) * 100);
      return `
        <div class="view-question">
          <div class="q-topbar">
            <button class="quit-btn" data-action="home">✕ QUIT</button>
            <span class="q-counter">QUESTION ${num} / ${total}</span>
          </div>
          <div class="progress-bar-wrap">
            <div class="progress-bar-fill" style="width:${pct}%;"></div>
          </div>
          <h1>${e(q.text)}</h1>
          <div class="options-grid">
            ${q.options.map((opt, i) => `
              <button class="option-btn" data-action="pick" data-key="${e(opt.key)}">
                <span class="option-letter">${'ABCD'[i]}</span>
                <span>${e(opt.label)}</span>
              </button>
            `).join('')}
          </div>
        </div>
      `;
    }

    function renderResults() {
      const quiz = quizzes[state.activeQuizId];
      const r = quiz.results[state.result];
      return `
        <div class="view-results">
          <div class="results-eyebrow">✦ THE ALGORITHM HAS SPOKEN ✦</div>
          <div class="results-youare">YOU ARE...</div>
          <div class="results-card">
            <div class="results-top" style="background:${e(r.color)};">
              <h1 class="results-name" style="color:${e(r.nameInk)};">${e(r.name)}</h1>
              <div class="results-kind" style="color:${e(r.nameInk)};">${e(r.kind)}</div>
            </div>
            <div class="results-body">
              <p class="results-tagline">${e(r.tagline)}</p>
              <p class="results-desc">${e(r.desc)}</p>
              <div class="results-traits">
                ${r.traits.map(t => `<span class="trait-chip">${e(t)}</span>`).join('')}
              </div>
              <div class="results-rarity">★ ONLY ${e(r.rarity)} OF PEOPLE GET THIS ★</div>
              <div class="share-label">SHARE YOUR DIAGNOSIS</div>
              <div class="share-grid">
                <button class="share-btn pink" data-action="share">📋 COPY LINK</button>
                <button class="share-btn cyan" data-action="share-tiktok">TIKTOK</button>
                <button class="share-btn yellow" data-action="share-insta">INSTA</button>
              </div>
              <div class="results-actions">
                <button class="btn-retake" data-action="retake">↻ TAKE AGAIN</button>
                <button class="btn-more" data-action="home">MORE QUIZZES →</button>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function renderBIntro() {
      const blitz = blitzes[state.activeBlitzId];
      return `
        <div class="view-bintro">
          <button class="back-link" data-action="home">← BACK TO QUIZZES</button>
          <div class="bintro-card">
            <div class="bintro-inner">
              <div class="bintro-bolt">⚡</div>
              <div class="bintro-eyebrow">PLAY-ALONG · BEAT THE CLOCK</div>
              <h1><span class="yellow">${e(blitz.title.toUpperCase())}</span></h1>
              <div class="bintro-chips">
                <span class="bintro-chip cyan">10 QUESTIONS</span>
                <span class="bintro-chip yellow">⏱ 10 SEC EACH</span>
                <span class="bintro-chip pink">🔥 BUILD A STREAK</span>
              </div>
              <p>Guess the emoji, name the flag, true-or-false and more. Tap fast — when the timer hits zero, the answer locks itself.</p>
              <button class="btn-go" data-action="startblitz">I'M READY — GO! →</button>
            </div>
          </div>
        </div>
      `;
    }

    function renderBQuestion() {
      const blitz = blitzes[state.activeBlitzId];
      const bq = blitz.questions[state.bIndex];
      const locked = state.bLocked;
      const picked = state.bPicked;
      const bTotal = blitz.questions.length;
      const danger = state.bTime <= 3;
      const timeColor = danger ? '#ff3b9a' : '#6c3bff';
      const timePct = Math.round((state.bTime / 10) * 100);

      const bOptions = bq.options.map((label, i) => {
        let bg = '#fff', fg = '#1a1430', mark = '';
        if (locked) {
          if (i === bq.correct) { bg = '#3bffd2'; fg = '#1a1430'; mark = '✓'; }
          else if (i === picked) { bg = '#ff3b9a'; fg = '#fff'; mark = '✗'; }
          else { bg = '#fbfaff'; fg = '#a79fc0'; }
        }
        return { label, letter: 'ABCD'[i], bg, fg, mark, idx: i };
      });

      return `
        <div class="view-bquestion">
          <div class="b-topbar">
            <button class="quit-btn" data-action="home">✕ QUIT</button>
            <div class="b-badges">
              <span class="b-badge dark">Q ${state.bIndex + 1} / ${bTotal}</span>
              <span class="b-badge cyan">⭐ ${state.bScore}</span>
              <span class="b-badge pink">🔥 ${state.bStreak}</span>
            </div>
          </div>
          <div class="timer-row">
            <span class="timer-num" style="color:${timeColor};">${state.bTime}</span>
            <div class="timer-bar-wrap">
              <div class="timer-bar-fill" style="width:${timePct}%;background:${timeColor};"></div>
            </div>
          </div>
          <div class="b-kind">${e(bq.kind)}</div>
          ${bq.prompt ? `<div class="b-prompt-box">${e(bq.prompt)}</div>` : ''}
          <h1>${e(bq.text)}</h1>
          <div class="b-options-grid">
            ${bOptions.map(opt => `
              <button class="b-option-btn" data-action="bpick" data-idx="${opt.idx}"
                style="background:${e(opt.bg)};color:${e(opt.fg)};"
                ${locked ? 'disabled' : ''}>
                <span class="b-option-letter">${e(opt.letter)}</span>
                <span style="flex:1;">${e(opt.label)}</span>
                <span class="b-option-mark">${e(opt.mark)}</span>
              </button>
            `).join('')}
          </div>
        </div>
      `;
    }

    function renderBResults() {
      const blitz = blitzes[state.activeBlitzId];
      const s = state.bScore;
      const bTotal = blitz.questions.length;
      let grade;
      if (s === bTotal) grade = { name: '🏆 QUIZ GOD', color: '#ffd23f', ink: '#1a1430', line: 'Flawless. Are you cheating? (We hope so.)' };
      else if (s >= bTotal * 0.8) grade = { name: '🧠 GALAXY BRAIN', color: '#6c3bff', ink: '#fff', line: 'Disgustingly smart. Please go outside.' };
      else if (s >= bTotal * 0.6) grade = { name: '😎 PRETTY SHARP', color: '#3bffd2', ink: '#1a1430', line: 'Respectable. The group chat is impressed.' };
      else if (s >= bTotal * 0.4) grade = { name: '🙂 NOT BAD', color: '#fffdf7', ink: '#1a1430', line: 'You won some, you lost some. Balance.' };
      else grade = { name: '💀 OOF', color: '#ff3b9a', ink: '#fff', line: 'It happens. Blame the timer. Run it back.' };

      return `
        <div class="view-bresults">
          <div class="bresults-eyebrow">⚡ BLITZ COMPLETE ⚡</div>
          <div class="bresults-card">
            <div class="bresults-top" style="background:${e(grade.color)};">
              <div class="bresults-label" style="color:${e(grade.ink)};">YOU SCORED</div>
              <div class="bresults-score" style="color:${e(grade.ink)};">${s} / ${bTotal}</div>
              <div class="bresults-grade" style="color:${e(grade.ink)};">${e(grade.name)}</div>
            </div>
            <div class="bresults-body">
              <p class="bresults-line">${e(grade.line)}</p>
              <div class="share-label">CHALLENGE A FRIEND</div>
              <div class="share-grid">
                <button class="share-btn pink" data-action="share">📋 COPY LINK</button>
                <button class="share-btn cyan" data-action="share-tiktok">TIKTOK</button>
                <button class="share-btn yellow" data-action="share-insta">INSTA</button>
              </div>
              <div class="results-actions">
                <button class="btn-retake" data-action="startblitz">↻ PLAY AGAIN</button>
                <button class="btn-more" data-action="home">MORE QUIZZES →</button>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    // ============================================================
    // RENDER
    // ============================================================
    function render() {
      const app = document.getElementById('app');
      switch (state.view) {
        case 'home':      app.innerHTML = renderHome(); break;
        case 'intro':     app.innerHTML = renderIntro(); break;
        case 'question':  app.innerHTML = renderQuestion(); break;
        case 'results':   app.innerHTML = renderResults(); break;
        case 'bintro':    app.innerHTML = renderBIntro(); break;
        case 'bquestion': app.innerHTML = renderBQuestion(); break;
        case 'bresults':  app.innerHTML = renderBResults(); break;
      }

      // Toast
      const toast = document.getElementById('toast');
      toast.style.display = state.shared ? 'block' : 'none';

      // Nav active states
      const isBlitzView = ['bintro','bquestion','bresults'].includes(state.view);
      const isQuizView  = ['home','intro','question','results'].includes(state.view);
      document.getElementById('nav-quizzes').classList.toggle('nav-btn--active', isQuizView && !isBlitzView);
      document.getElementById('nav-blitz').classList.toggle('nav-btn--active', isBlitzView);

      // Scroll to top on view change
      window.scrollTo({ top: 0, behavior: 'instant' });
    }

    // ============================================================
    // EVENT DELEGATION
    // ============================================================
    function handleAction(el) {
      const action = el.dataset.action;
      if (!action) return;
      switch (action) {
        case 'home':       goHome(); break;
        case 'quiz':       openQuiz(el.dataset.id); break;
        case 'random':     openRandom(); break;
        case 'blitz':      openBlitz(el.dataset.id); break;
        case 'start':      startQuiz(); break;
        case 'startblitz': startBlitz(); break;
        case 'pick':       pickAnswer(el.dataset.key); break;
        case 'bpick':      lockBlitz(parseInt(el.dataset.idx)); break;
        case 'retake':     retakeQuiz(); break;
        case 'browse':        document.getElementById('cat-chips-section')?.scrollIntoView({ behavior: 'smooth' }); break;
        case 'share':         doShare(); break;
        case 'share-tiktok':  doShareTikTok(); break;
        case 'share-insta':   doShareInsta(); break;
        case 'filter':        filterCat(el.dataset.cat); break;
        case 'categories':    openCategories(); break;
      }
    }

    document.addEventListener('click', (ev) => {
      const el = ev.target.closest('[data-action]');
      if (el) handleAction(el);
    });

    // Header buttons
    document.getElementById('logo-btn').addEventListener('click', goHome);
    document.getElementById('nav-quizzes').addEventListener('click', goHome);
    document.getElementById('nav-blitz').href = `/blitz/${getTodayBlitzId()}`;
    document.getElementById('nav-random').addEventListener('click', openRandom);
    document.getElementById('nav-categories').addEventListener('click', openCategories);

    // Initial render
    render();
  </script>
</body>
</html>
