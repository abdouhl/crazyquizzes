---
import catsData    from '../data/categories.json';
import cardsData   from '../data/cards.json';
import quizzesData from '../data/quizzes.json';
import blitzesData from '../data/blitzes.json';

const homeJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://crazyquizzes.com/#website',
      url: 'https://crazyquizzes.com/',
      name: 'CrazyQuizzes',
      description: "The Internet's Dumbest Quiz Site — personality quizzes, trivia blitzes, and emoji games.",
      publisher: { '@type': 'Organization', name: 'CrazyQuizzes', url: 'https://crazyquizzes.com' },
    },
    {
      '@type': 'ItemList',
      name: 'Quizzes & Trivia Blitzes',
      url: 'https://crazyquizzes.com/',
      numberOfItems: (cardsData as any[]).length,
      itemListElement: (cardsData as any[]).slice(0, 10).map((card, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: card.title,
        url: `https://crazyquizzes.com/${card.type === 'blitz' ? 'blitz' : 'quiz'}/${card.id}`,
      })),
    },
  ],
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CrazyQuizzes — The Internet's Dumbest Quiz Site</title>
  <meta name="description" content="Take a quiz. Get judged by an algorithm with zero credentials. Send the results to the group chat." />
  <link rel="canonical" href="https://crazyquizzes.com/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CrazyQuizzes" />
  <meta property="og:url" content="https://crazyquizzes.com/" />
  <meta property="og:title" content="CrazyQuizzes — The Internet's Dumbest Quiz Site" />
  <meta property="og:description" content="Take a quiz. Get judged by an algorithm with zero credentials. Send the results to the group chat." />
  <meta property="og:image" content="https://crazyquizzes.com/og-default.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="CrazyQuizzes — The Internet's Dumbest Quiz Site" />
  <meta name="twitter:description" content="Take a quiz. Get judged by an algorithm with zero credentials. Send the results to the group chat." />
  <meta name="twitter:image" content="https://crazyquizzes.com/og-default.png" />

  <script type="application/ld+json" set:html={homeJsonLd} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bungee&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    @keyframes cq-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @keyframes cq-blink { 0%, 55% { opacity: 1; } 56%, 100% { opacity: 0; } }
    @keyframes cq-float { 0%, 100% { transform: translateY(0) rotate(var(--r,0deg)); } 50% { transform: translateY(-12px) rotate(var(--r,0deg)); } }
    @keyframes cq-spin { to { transform: rotate(360deg); } }
    @keyframes cq-wiggle { 0%, 100% { transform: rotate(-4deg); } 50% { transform: rotate(4deg); } }
    @keyframes cq-pop { 0% { transform: scale(.6); opacity: 0; } 65% { transform: scale(1.1); } 100% { transform: scale(1); opacity: 1; } }

    body {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      color: #1a1430;
      background-color: #f3eeff;
      background-image: linear-gradient(rgba(108,59,255,.08) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(108,59,255,.08) 1px, transparent 1px);
      background-size: 28px 28px;
      overflow-x: hidden;
    }

    .marquee-bar {
      background: #1a1430;
      border-bottom: 3px solid #1a1430;
      overflow: hidden;
      white-space: nowrap;
      padding: 9px 0;
    }
    .marquee-track {
      display: inline-block;
      white-space: nowrap;
      animation: cq-marquee 22s linear infinite;
      font-family: 'Bungee', cursive;
      font-size: 13px;
      letter-spacing: .04em;
      color: #3bffd2;
    }
    .marquee-track span { padding: 0 6px; }

    header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: #fffdf7;
      border-bottom: 3px solid #1a1430;
      box-shadow: 0 4px 0 rgba(26,20,48,.12);
    }
    .header-inner {
      max-width: 1140px;
      margin: 0 auto;
      padding: 12px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      text-decoration: none;
    }
    .logo-star {
      font-family: 'Bungee', cursive;
      color: #6c3bff;
      display: inline-block;
      animation: cq-spin 7s linear infinite;
      font-size: 22px;
    }
    .logo-text {
      font-family: 'Bungee', cursive;
      font-size: clamp(18px, 3vw, 24px);
      letter-spacing: .01em;
    }
    .logo-text .crazy { color: #6c3bff; }
    .logo-text .quizzes { color: #1a1430; }

    nav {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      font-family: 'Bungee', cursive;
      font-size: 11px;
    }
    .nav-btn {
      cursor: pointer;
      text-decoration: none;
      color: #1a1430;
      border: 2px solid #1a1430;
      padding: 7px 12px;
      box-shadow: 3px 3px 0 #1a1430;
      transition: transform .1s, box-shadow .1s;
      background: #3bffd2;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      display: inline-block;
    }
    .nav-btn:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #1a1430; }
    .nav-btn--active { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 #1a1430; outline: 3px solid #1a1430; outline-offset: 2px; }
    .nav-btn.yellow { background: #ffd23f; }
    .nav-btn.pink { background: #ff3b9a; color: #fff; }
    .nav-plain {
      cursor: pointer;
      text-decoration: none;
      color: #1a1430;
      padding: 7px 6px;
      opacity: .7;
      font-family: 'Bungee', cursive;
      font-size: 11px;
    }

    #app {
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 22px;
    }

    /* ---- HOME ---- */
    .hero {
      position: relative;
      padding: 54px 0 36px;
    }
    .hero-sticker {
      position: absolute;
      top: 18px;
      right: 6px;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      background: #ffd23f;
      border: 3px solid #1a1430;
      box-shadow: 4px 4px 0 #1a1430;
      padding: 10px 12px;
      transform: rotate(7deg);
      animation: cq-wiggle 2.6s ease-in-out infinite;
      text-align: center;
      line-height: 1.3;
      max-width: 140px;
    }
    .hero-badge {
      display: inline-block;
      font-family: 'Bungee', cursive;
      font-size: 12px;
      background: #1a1430;
      color: #3bffd2;
      padding: 7px 12px;
      border: 3px solid #1a1430;
      box-shadow: 4px 4px 0 #6c3bff;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-family: 'Bungee', cursive;
      font-size: clamp(38px, 7.4vw, 88px);
      line-height: .96;
      margin: 0 0 18px;
      max-width: 14ch;
      text-shadow: 5px 5px 0 #3bffd2;
    }
    .hero h1 .purple { color: #6c3bff; text-shadow: 5px 5px 0 #ff3b9a; }
    .hero p {
      font-size: clamp(16px, 2.2vw, 21px);
      max-width: 46ch;
      font-weight: 500;
      line-height: 1.45;
      margin: 0 0 28px;
    }
    .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
    .btn-primary {
      font-family: 'Bungee', cursive;
      font-size: clamp(14px, 2vw, 17px);
      color: #fff;
      background: #6c3bff;
      border: 3px solid #1a1430;
      box-shadow: 6px 6px 0 #1a1430;
      padding: 16px 26px;
      cursor: pointer;
      transition: transform .1s, box-shadow .1s;
    }
    .btn-primary:hover { transform: translate(-2px,-2px); box-shadow: 8px 8px 0 #1a1430; }
    .btn-secondary {
      font-family: 'Bungee', cursive;
      font-size: clamp(14px, 2vw, 17px);
      color: #1a1430;
      background: #fffdf7;
      border: 3px solid #1a1430;
      box-shadow: 6px 6px 0 #1a1430;
      padding: 16px 26px;
      cursor: pointer;
      transition: transform .1s, box-shadow .1s;
    }
    .btn-secondary:hover { transform: translate(-2px,-2px); box-shadow: 8px 8px 0 #3bffd2; }

    .cat-chips { padding: 8px 0 30px; display: flex; gap: 10px; flex-wrap: wrap; }
    .chip {
      font-family: 'Bungee', cursive;
      font-size: 11px;
      border: 2px solid #1a1430;
      box-shadow: 3px 3px 0 #1a1430;
      padding: 8px 13px;
      cursor: pointer;
      transition: transform .1s, box-shadow .1s;
      user-select: none;
    }
    .chip:hover { transform: translateY(-2px); box-shadow: 3px 5px 0 #1a1430; }
    .chip--active {
      transform: translate(-2px, -2px) !important;
      box-shadow: 5px 5px 0 #6c3bff !important;
      outline: 3px solid #6c3bff;
      outline-offset: 1px;
    }

    .blitz-banner {
      position: relative;
      overflow: hidden;
      background: #1a1430;
      border: 3px solid #1a1430;
      box-shadow: 9px 9px 0 #6c3bff;
      cursor: pointer;
      padding: 30px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
      transition: transform .12s, box-shadow .12s;
      margin-bottom: 36px;
      text-decoration: none;
    }
    .blitz-banner:hover { transform: translate(-3px,-3px); box-shadow: 12px 12px 0 #6c3bff; }
    .blitz-bg-icon {
      position: absolute;
      top: -12px;
      right: -8px;
      font-size: 120px;
      opacity: .08;
      line-height: 1;
      pointer-events: none;
    }
    .blitz-eyebrow {
      font-family: 'Bungee', cursive;
      font-size: 11px;
      color: #3bffd2;
      margin-bottom: 12px;
    }
    .blitz-banner h2 {
      font-family: 'Bungee', cursive;
      font-size: clamp(28px, 5.2vw, 50px);
      line-height: .98;
      color: #fff;
      margin: 0 0 12px;
    }
    .blitz-banner h2 .yellow { color: #ffd23f; }
    .blitz-banner p { color: #b3a9d6; font-weight: 500; font-size: 15px; line-height: 1.45; margin: 0; }
    .blitz-right { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
    .blitz-emojis { display: flex; gap: 10px; font-size: 34px; line-height: 1; animation: cq-wiggle 2.6s ease-in-out infinite; }
    .blitz-play-btn {
      font-family: 'Bungee', cursive;
      font-size: 15px;
      color: #1a1430;
      background: #3bffd2;
      border: 3px solid #3bffd2;
      box-shadow: 5px 5px 0 #ff3b9a;
      padding: 14px 22px;
      cursor: pointer;
    }

    .trending-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .trending-header h2 { font-family: 'Bungee', cursive; font-size: clamp(22px, 3.5vw, 34px); margin: 0; }
    .live-badge {
      font-weight: 600;
      font-size: 13px;
      background: #ff3b9a;
      color: #fff;
      border: 2px solid #1a1430;
      padding: 3px 9px;
      animation: cq-blink 1.4s steps(1) infinite;
      font-family: 'Space Grotesk', sans-serif;
    }

    .quiz-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 22px;
      padding-bottom: 60px;
    }
    .quiz-card {
      background: #fff;
      border: 3px solid #1a1430;
      box-shadow: 6px 6px 0 #1a1430;
      cursor: pointer;
      transition: transform .12s, box-shadow .12s;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .quiz-card:hover { transform: translate(-3px,-3px); box-shadow: 9px 9px 0 #6c3bff; }
    .quiz-card-cover {
      height: 152px;
      border-bottom: 3px solid #1a1430;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .quiz-card-cover-emoji {
      font-size: 56px;
      line-height: 1;
      filter: drop-shadow(0 4px 14px rgba(0,0,0,.45));
      user-select: none;
      letter-spacing: .05em;
    }
    .quiz-card-badge {
      position: absolute;
      top: 10px;
      right: 10px;
      font-family: 'Bungee', cursive;
      font-size: 10px;
      border: 2px solid #1a1430;
      box-shadow: 2px 2px 0 #1a1430;
      padding: 4px 8px;
      transform: rotate(6deg);
    }
    .quiz-card-body { padding: 16px 16px 18px; }
    .quiz-card-cat { font-family: 'Bungee', cursive; font-size: 10px; color: #6c3bff; margin-bottom: 8px; }
    .quiz-card-title { font-weight: 700; font-size: 19px; line-height: 1.18; margin: 0 0 12px; }
    .quiz-card-footer { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .quiz-card-takes { font-size: 12px; font-weight: 600; color: #6b6285; }
    .quiz-card-play { font-family: 'Bungee', cursive; font-size: 10px; color: #fff; background: #1a1430; padding: 5px 9px; }

    /* ---- FOOTER ---- */
    footer {
      margin: 0 -22px;
      border-top: 3px solid #1a1430;
      background: #1a1430;
      color: #f3eeff;
      padding: 40px 22px 30px;
    }
    .footer-inner {
      max-width: 1140px;
      margin: 0 auto;
      display: flex;
      gap: 30px;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
    }
    .footer-brand { max-width: 300px; }
    .footer-logo { font-family: 'Bungee', cursive; font-size: 22px; margin-bottom: 10px; }
    .footer-logo .crazy { color: #3bffd2; }
    .footer-logo .quizzes { color: #fff; }
    .footer-desc { font-size: 13px; line-height: 1.5; color: #b3a9d6; margin: 0 0 14px; }
    .footer-tagline { font: 600 10px/1 'Courier New', monospace; color: #3bffd2; letter-spacing: .1em; }
    .footer-counter-label { font-family: 'Bungee', cursive; font-size: 11px; color: #ffd23f; margin-bottom: 12px; }
    .counter-digits { display: flex; gap: 4px; }
    .counter-digit {
      font: 700 18px/1 'Courier New', monospace;
      background: #000;
      color: #3bffd2;
      border: 2px solid #3bffd2;
      padding: 6px 5px;
    }
    .footer-wip {
      margin-top: 16px;
      height: 46px;
      border: 2px dashed #6c3bff;
      display: flex;
      align-items: center;
      justify-content: center;
      font: 600 10px/1 'Courier New', monospace;
      color: #6c3bff;
      letter-spacing: .1em;
    }
    .footer-sitemap { font-family: 'Bungee', cursive; font-size: 11px; display: flex; flex-direction: column; gap: 10px; }
    .footer-sitemap .label { color: #ff3b9a; }
    .footer-sitemap a { color: #fff; text-decoration: none; cursor: pointer; }
    .footer-bottom {
      max-width: 1140px;
      margin: 26px auto 0;
      border-top: 1px solid #3a3358;
      padding-top: 16px;
      font-size: 12px;
      color: #8479a8;
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      justify-content: space-between;
    }

    /* ---- INTRO ---- */
    .view-intro { padding: 40px 0 70px; max-width: 680px; margin: 0 auto; }
    .back-link {
      display: inline-block;
      cursor: pointer;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      color: #6c3bff;
      margin-bottom: 22px;
      background: none;
      border: none;
      padding: 0;
    }
    .intro-card {
      background: #fff;
      border: 3px solid #1a1430;
      box-shadow: 8px 8px 0 #1a1430;
    }
    .intro-cover {
      height: 220px;
      border-bottom: 3px solid #1a1430;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      background: repeating-linear-gradient(45deg, #efe7ff, #efe7ff 13px, #f8f4ff 13px, #f8f4ff 26px);
    }
    .intro-cover-label {
      font: 600 12px/1 'Courier New', monospace;
      letter-spacing: .12em;
      color: #6c3bff;
      text-transform: uppercase;
      background: #fff;
      border: 2px solid #1a1430;
      padding: 6px 11px;
    }
    .intro-viral {
      position: absolute;
      top: 14px;
      left: 14px;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      background: #ff3b9a;
      color: #fff;
      border: 2px solid #1a1430;
      box-shadow: 2px 2px 0 #1a1430;
      padding: 5px 9px;
      transform: rotate(-5deg);
    }
    .intro-body { padding: 30px 28px 32px; }
    .intro-cat { font-family: 'Bungee', cursive; font-size: 11px; color: #6c3bff; margin-bottom: 12px; }
    .intro-body h1 {
      font-family: 'Bungee', cursive;
      font-size: clamp(26px, 5vw, 40px);
      line-height: 1.02;
      margin: 0 0 16px;
    }
    .intro-body p { font-size: 16px; font-weight: 500; line-height: 1.5; color: #3a3358; margin: 0 0 22px; }
    .intro-meta { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 26px; }
    .meta-chip {
      font-family: 'Bungee', cursive;
      font-size: 11px;
      border: 2px solid #1a1430;
      padding: 7px 11px;
      box-shadow: 2px 2px 0 #1a1430;
    }
    .btn-start {
      width: 100%;
      font-family: 'Bungee', cursive;
      font-size: 19px;
      color: #fff;
      background: #6c3bff;
      border: 3px solid #1a1430;
      box-shadow: 6px 6px 0 #1a1430;
      padding: 18px;
      cursor: pointer;
      transition: transform .1s, box-shadow .1s;
    }
    .btn-start:hover { transform: translate(-2px,-2px); box-shadow: 8px 8px 0 #ff3b9a; }

    /* ---- QUESTION ---- */
    .view-question { padding: 36px 0 70px; max-width: 760px; margin: 0 auto; }
    .q-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
    .quit-btn {
      cursor: pointer;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      color: #6c3bff;
      background: none;
      border: none;
      padding: 0;
    }
    .q-counter { font-family: 'Bungee', cursive; font-size: 12px; }
    .progress-bar-wrap {
      height: 22px;
      border: 3px solid #1a1430;
      background: #fff;
      box-shadow: 4px 4px 0 #1a1430;
      margin-bottom: 30px;
      overflow: hidden;
    }
    .progress-bar-fill {
      height: 100%;
      background: repeating-linear-gradient(45deg, #6c3bff, #6c3bff 8px, #8a63ff 8px, #8a63ff 16px);
      transition: width .3s ease;
    }
    .view-question h1 {
      font-family: 'Bungee', cursive;
      font-size: clamp(24px, 4.4vw, 38px);
      line-height: 1.08;
      margin: 0 0 28px;
    }
    .options-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }
    .option-btn {
      text-align: left;
      display: flex;
      align-items: center;
      gap: 14px;
      background: #fff;
      border: 3px solid #1a1430;
      box-shadow: 5px 5px 0 #1a1430;
      padding: 18px 20px;
      cursor: pointer;
      font: 600 17px/1.3 'Space Grotesk', sans-serif;
      color: #1a1430;
      transition: transform .1s, box-shadow .1s, background .1s;
    }
    .option-btn:hover { transform: translate(-3px,-3px); box-shadow: 8px 8px 0 #6c3bff; background: #f8f4ff; }
    .option-letter {
      flex: none;
      width: 36px;
      height: 36px;
      background: #6c3bff;
      color: #fff;
      border: 2px solid #1a1430;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Bungee', cursive;
      font-size: 14px;
    }

    /* ---- RESULTS ---- */
    .view-results { padding: 40px 0 70px; max-width: 680px; margin: 0 auto; text-align: center; }
    .results-eyebrow {
      font-family: 'Bungee', cursive;
      font-size: 13px;
      color: #6c3bff;
      margin-bottom: 6px;
      animation: cq-wiggle 2.6s ease-in-out infinite;
      display: inline-block;
    }
    .results-youare { font-family: 'Bungee', cursive; font-size: clamp(16px,3vw,20px); margin-bottom: 18px; }
    .results-card {
      background: #fff;
      border: 3px solid #1a1430;
      box-shadow: 8px 8px 0 #1a1430;
      animation: cq-pop .45s ease both;
      overflow: hidden;
    }
    .results-top { border-bottom: 3px solid #1a1430; padding: 30px 24px; }
    .results-name {
      font-family: 'Bungee', cursive;
      font-size: clamp(34px, 7vw, 62px);
      line-height: .98;
      margin: 0;
      text-shadow: 4px 4px 0 rgba(26,20,48,.18);
    }
