    let tickTimer = null;
    let advTimer = null;

    function setState(updates) {
      state = { ...state, ...updates };
      render();
    }

    // ============================================================
    // ACTIONS
    // ============================================================
    function goHome() {
      clearTimers();
      setState({ view: 'home', shared: false });
