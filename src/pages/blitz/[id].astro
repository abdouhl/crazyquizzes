  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>›</span>
    <a href="/trivia-quizzes">Trivia Blitzes</a>
    <span>›</span>
    {blitz.title}
  </nav>

  <div id="app">
    <!-- Static fallback for crawlers -->
    <div class="view-bintro">
      <a href="/" class="back-link">← BACK TO QUIZZES</a>
      <div class="bintro-card">
        <div class="bintro-inner">
          {blitz.coverImg
            ? <div class="bintro-cover-img-wrap"><img class="bintro-cover-img" src={blitz.coverImg} alt={blitz.title} loading="lazy" referrerpolicy="no-referrer" /></div>
            : <div class="bintro-bolt">⚡</div>
          }
          <div class="bintro-eyebrow">PLAY-ALONG · BEAT THE CLOCK</div>
          <h1><span class="yellow">{blitz.title.toUpperCase()}</span></h1>
          <div class="bintro-chips">
            <span class="bintro-chip cyan">10 QUESTIONS</span>
            <span class="bintro-chip yellow">⏱ 10 SEC EACH</span>
            <span class="bintro-chip pink">🔥 BUILD A STREAK</span>
          </div>
          <p>{blitz.desc || 'Guess the emoji, name the flag, true-or-false and more. Tap fast — when the timer hits zero, the answer locks itself.'}</p>
          <button class="btn-go" id="static-go-btn">I'M READY — GO! →</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Ad zone — shown on intro/results, hidden during questions. Add <ins> ad unit here after creating one in AdSense → Ads → Ad units -->
  <div id="cq-ad-zone" style="max-width:728px;margin:0 auto;padding:0 22px;display:block;"></div>

  <div id="toast" class="toast" style="display:none;">✓ LINK COPIED — GO RUIN SOMEONE'S DAY</div>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></div>
        <p class="footer-desc">Diagnosing your personality with snacks since right now. Results may be used against you in the group chat.</p>
        <div class="footer-tagline">★ BEST VIEWED IN NETSCAPE NAVIGATOR 4.0 ★</div>
        <a href="https://www.pinterest.com/crazyquizzes/" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;margin-top:14px;background:#e60023;color:#fff;font-family:'Bungee',cursive;font-size:11px;padding:8px 14px;border:2px solid #1a1430;box-shadow:3px 3px 0 #1a1430;text-decoration:none;"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>PINTEREST</a>
      </div>
      <div class="footer-sitemap">
        <span class="label">QUIZZES</span>
        <a href="/">All Quizzes</a>
        <a href="/personality-quizzes">Personality Quizzes</a>
        <a href="/trivia-quizzes">Trivia Blitzes</a>
        <a href="/" id="footer-blitz">Daily Blitz</a>
        <span class="label">COMPANY</span>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Use</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 CrazyQuizzes.com — made with ♥ and zero focus groups</span>
      <span>crazyquizzes.com</span>
    </div>
  </footer>

  <script define:vars={{ blitzes: blitzesData, cards: cardsData, initialBlitzId: id }}>
    let state = {
      view: 'bintro',
      activeBlitzId: initialBlitzId,
      bIndex: 0,
      bTime: 10,
      bLocked: false,
      bPicked: null,
      bScore: 0,
      bStreak: 0,
      bMaxStreak: 0,
      bAnswers: [],
    };

    let tickTimer = null;
    let advTimer = null;

    function setState(u) { state = { ...state, ...u }; render(); }

    function getTodayBlitzId() {
      const keys = Object.keys(blitzes);
      return keys[Math.floor(Date.now() / 86400000) % keys.length];
    }

    function openRandom() {
      const blitzIds = cards.filter(c => c.type === 'blitz').map(c => c.id);
      const quizIds  = cards.filter(c => c.type !== 'blitz').map(c => c.id);
      const all = [...blitzIds.map(id => ({ type: 'blitz', id })), ...quizIds.map(id => ({ type: 'quiz', id }))];
      const pick = all[Math.floor(Math.random() * all.length)];
      window.location.href = pick.type === 'blitz' ? `/blitz/${pick.id}` : `/quiz/${pick.id}`;
    }

    function startBlitz() {
      clearTimers();
      setState({ view: 'bquestion', bIndex: 0, bTime: 10, bLocked: false, bPicked: null, bScore: 0, bStreak: 0, bMaxStreak: 0, bAnswers: [] });
      tickTimer = setInterval(tick, 1000);
    }
    function tick() {
      if (state.view !== 'bquestion' || state.bLocked) return;
      const t = state.bTime - 1;
      if (t <= 0) { setState({ bTime: 0 }); lockBlitz(-1); }
      else setState({ bTime: t });
    }
    function lockBlitz(idx) {
      if (state.bLocked) return;
      const blitz = blitzes[state.activeBlitzId];
      const q = blitz.questions[state.bIndex];
      const correct = idx === q.correct;
      const newStreak = correct ? state.bStreak + 1 : 0;
      const newMaxStreak = Math.max(state.bMaxStreak, newStreak);
      const newAnswers = [...state.bAnswers, {
        qText: q.text,
        correct,
        timedOut: idx === -1,
        pickedLabel: idx >= 0 ? q.options[idx] : null,
        correctLabel: q.options[q.correct],
      }];
      setState({ bLocked: true, bPicked: idx, bScore: state.bScore + (correct ? 1 : 0), bStreak: newStreak, bMaxStreak: newMaxStreak, bAnswers: newAnswers });
      advTimer = setTimeout(nextBlitz, 1500);
    }
    function nextBlitz() {
      const blitz = blitzes[state.activeBlitzId];
      const next = state.bIndex + 1;
      if (next >= blitz.questions.length) { clearTimers(); setState({ view: 'bresults' }); }
      else setState({ bIndex: next, bTime: 10, bLocked: false, bPicked: null });
    }
    function clearTimers() { clearInterval(tickTimer); clearTimeout(advTimer); }

    function getShareText() {
      const blitz = blitzes[state.activeBlitzId];
      const total = blitz.questions.length;
      return `I scored ${state.bScore}/${total} on "${blitz.title}"! Think you can beat me? 👀\n${window.location.href}`;
    }
    function doShare() {
      const text = getShareText();
      navigator.clipboard.writeText(text).catch(() => {});
      showToast('✓ SCORE COPIED — GO CHALLENGE SOMEONE');
    }
    function doShareTikTok() {
      const shareData = { title: document.title, text: getShareText(), url: window.location.href };
      if (navigator.share) navigator.share(shareData).catch(() => {});
      else { navigator.clipboard.writeText(getShareText()).catch(() => {}); showToast('COPIED — PASTE IN YOUR TIKTOK BIO 🎵'); }
    }
    function doShareInsta() {
      const shareData = { title: document.title, text: getShareText(), url: window.location.href };
      if (navigator.share) navigator.share(shareData).catch(() => {});
      else { navigator.clipboard.writeText(getShareText()).catch(() => {}); showToast('COPIED — ADD TO YOUR INSTA STORY 📸'); }
    }
    function spawnConfetti() {
      const colors = ['#6c3bff','#3bffd2','#ff3b9a','#ffd23f','#fff','#1a1430'];
      const wrap = document.createElement('div');
      wrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;overflow:hidden;';
      for (let i = 0; i < 90; i++) {
        const p = document.createElement('div');
        const color = colors[i % colors.length];
        const left  = Math.random() * 100;
        const delay = Math.random() * 1.4;
        const dur   = 2.5 + Math.random() * 1.8;
        const size  = 7 + Math.random() * 9;
        const isRect = Math.random() > 0.4;
        p.style.cssText = `position:absolute;left:${left}%;top:-20px;width:${size}px;height:${isRect ? size * 1.6 : size}px;background:${color};border:1px solid rgba(0,0,0,.12);animation:cq-confetti ${dur}s ${delay}s ease-in both;`;
        wrap.appendChild(p);
      }
      document.body.appendChild(wrap);
      setTimeout(() => wrap.remove(), 5500);
    }
    function showToast(msg) {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg;
      t.style.display = 'block';
      clearTimeout(showToast._tid);
      showToast._tid = setTimeout(() => { t.style.display = 'none'; }, 2800);
    }

    function e(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function renderBIntro() {
      const blitz = blitzes[state.activeBlitzId];
      return `
        <div class="view-bintro">
          <a href="/" class="back-link">← BACK TO QUIZZES</a>
          <div class="bintro-card">
            <div class="bintro-inner">
              ${blitz.coverImg ? `<div class="bintro-cover-img-wrap"><img class="bintro-cover-img" src="${e(blitz.coverImg)}" alt="${e(blitz.title)}" loading="lazy" referrerpolicy="no-referrer"></div>` : `<div class="bintro-bolt">⚡</div>`}
              <div class="bintro-eyebrow">PLAY-ALONG · BEAT THE CLOCK</div>
              <h1><span class="yellow">${e(blitz.title.toUpperCase())}</span></h1>
              <div class="bintro-chips">
                <span class="bintro-chip cyan">10 QUESTIONS</span>
                <span class="bintro-chip yellow">⏱ 10 SEC EACH</span>
                <span class="bintro-chip pink">🔥 BUILD A STREAK</span>
              </div>
              <p>${e(blitz.desc || 'Guess the emoji, name the flag, true-or-false and more. Tap fast — when the timer hits zero, the answer locks itself.')}</p>
              <button class="btn-go" data-action="startblitz">I'M READY — GO! →</button>
            </div>
          </div>
        </div>
      `;
    }

    function renderBQuestion() {
      const blitz = blitzes[state.activeBlitzId];
      const bq = blitz.questions[state.bIndex];
      const locked = state.bLocked;
      const picked = state.bPicked;
      const bTotal = blitz.questions.length;
      const danger = state.bTime <= 3;
      const timeColor = danger ? '#ff3b9a' : '#6c3bff';
      const timePct = Math.round((state.bTime / 10) * 100);

      const bOptions = bq.options.map((label, i) => {
        let bg = '#fff', fg = '#1a1430', mark = '';
        if (locked) {
          if (i === bq.correct) { bg = '#3bffd2'; fg = '#1a1430'; mark = '✓'; }
          else if (i === picked) { bg = '#ff3b9a'; fg = '#fff'; mark = '✗'; }
          else { bg = '#fbfaff'; fg = '#a79fc0'; }
        }
        return { label, letter: 'ABCD'[i], bg, fg, mark, idx: i };
      });

      return `
        <div class="view-bquestion">
          <div class="b-topbar">
            <button class="quit-btn" data-action="home">✕ QUIT</button>
            <div class="b-badges">
              <span class="b-badge dark">Q ${state.bIndex + 1} / ${bTotal}</span>
              <span class="b-badge cyan">⭐ ${state.bScore}</span>
              <span class="b-badge pink">🔥 ${state.bStreak}</span>
            </div>
          </div>
          <div class="timer-row">
            <span class="timer-num${danger ? ' danger' : ''}" style="color:${timeColor};">${state.bTime}</span>
            <div class="timer-bar-wrap">
              <div class="timer-bar-fill" style="width:${timePct}%;background:${timeColor};"></div>
            </div>
          </div>
          <div class="b-kind">${e(bq.kind)}</div>
          ${bq.image ? `<div class="bq-img-wrap"><img class="bq-img" src="${e(bq.image)}" alt="Guess who?" loading="lazy" referrerpolicy="no-referrer"></div>` : bq.prompt ? `<div class="b-prompt-box">${e(bq.prompt)}</div>` : ''}
          <h1>${e(bq.text)}</h1>
          <div class="b-options-grid">
            ${bOptions.map(opt => `
              <button class="b-option-btn" data-action="bpick" data-idx="${opt.idx}"
                style="background:${e(opt.bg)};color:${e(opt.fg)};"
                ${locked ? 'disabled' : ''}>
                <span class="b-option-letter">${e(opt.letter)}</span>
                <span style="flex:1;">${e(opt.label)}</span>
                <span class="b-option-mark">${e(opt.mark)}</span>
              </button>
            `).join('')}
          </div>
          <div class="key-hint">Press <kbd>1</kbd> <kbd>2</kbd> <kbd>3</kbd> <kbd>4</kbd> to answer</div>
        </div>
      `;
    }

    function renderBResults() {
      const blitz = blitzes[state.activeBlitzId];
      const s = state.bScore;
      const bTotal = blitz.questions.length;
      let grade;
      if (s === bTotal) grade = { name: '🏆 QUIZ GOD', color: '#ffd23f', ink: '#1a1430', line: 'Flawless. Are you cheating? (We hope so.)' };
      else if (s >= bTotal * 0.8) grade = { name: '🧠 GALAXY BRAIN', color: '#6c3bff', ink: '#fff', line: 'Disgustingly smart. Please go outside.' };
      else if (s >= bTotal * 0.6) grade = { name: '😎 PRETTY SHARP', color: '#3bffd2', ink: '#1a1430', line: 'Respectable. The group chat is impressed.' };
      else if (s >= bTotal * 0.4) grade = { name: '🙂 NOT BAD', color: '#fffdf7', ink: '#1a1430', line: 'You won some, you lost some. Balance.' };
      else grade = { name: '💀 OOF', color: '#ff3b9a', ink: '#fff', line: 'It happens. Blame the timer. Run it back.' };

      if (s === bTotal) setTimeout(spawnConfetti, 350);

      const answers = state.bAnswers || [];
      const reviewHTML = answers.map((a, i) => {
        const cls  = a.timedOut ? 'timeout' : (a.correct ? 'ok' : 'wrong');
        const mark = a.timedOut ? '⏱' : (a.correct ? '✓' : '✗');
        return `
          <div class="brq-item ${cls}">
            <span class="brq-num">${i + 1}</span>
            <div class="brq-info">
              <div class="brq-text">${e(a.qText)}</div>
              ${a.timedOut ? `<div class="brq-answer">⏱ Timed out — ${e(a.correctLabel)}</div>` :
                !a.correct ? `<div class="brq-answer">✓ ${e(a.correctLabel)}</div>` : ''}
            </div>
            <span class="brq-mark">${mark}</span>
          </div>
        `;
      }).join('');

      return `
        <div class="view-bresults">
          <div class="bresults-eyebrow">⚡ BLITZ COMPLETE ⚡</div>
          <div class="bresults-card">
            <div class="bresults-top" style="background:${e(grade.color)};">
              <div class="bresults-label" style="color:${e(grade.ink)};">YOU SCORED</div>
              <div class="bresults-score" style="color:${e(grade.ink)};">${s} / ${bTotal}</div>
              <div class="bresults-grade" style="color:${e(grade.ink)};">${e(grade.name)}</div>
            </div>
            <div class="bresults-stats">
              <div class="bresults-stat">
                <div class="bresults-stat-num">${s}</div>
                <div class="bresults-stat-lbl">CORRECT</div>
              </div>
              <div class="bresults-stat">
                <div class="bresults-stat-num">${bTotal - s}</div>
                <div class="bresults-stat-lbl">MISSED</div>
              </div>
              <div class="bresults-stat">
                <div class="bresults-stat-num">${state.bMaxStreak}</div>
                <div class="bresults-stat-lbl">BEST STREAK</div>
              </div>
              <div class="bresults-stat">
                <div class="bresults-stat-num">${Math.round((s / bTotal) * 100)}%</div>
                <div class="bresults-stat-lbl">ACCURACY</div>
              </div>
            </div>
            <div class="bresults-body">
              <p class="bresults-line">${e(grade.line)}</p>
              <div class="share-label">CHALLENGE A FRIEND</div>
              <div class="share-grid">
                <button class="share-btn pink" data-action="share">📋 COPY SCORE</button>
                <button class="share-btn cyan" data-action="share-tiktok">TIKTOK</button>
                <button class="share-btn yellow" data-action="share-insta">INSTA</button>
              </div>
              <div class="results-actions">
                <button class="btn-retake" data-action="startblitz">↻ PLAY AGAIN</button>
                <button class="btn-more" data-action="home">MORE QUIZZES →</button>
              </div>
              ${reviewHTML ? `
              <div class="brq-wrap">
                <div class="brq-title">QUESTION REVIEW</div>
                ${reviewHTML}
              </div>` : ''}
            </div>
          </div>
        </div>
      `;
    }

    function render() {
      const app = document.getElementById('app');
      const adZone = document.getElementById('cq-ad-zone');
      const footer = document.querySelector('footer');
      const playing = state.view === 'bquestion';
      document.body.classList.toggle('quiz-playing', playing);
      if (footer) footer.style.display = playing ? 'none' : '';
      if (adZone) adZone.style.display = playing ? 'none' : 'block';
      switch (state.view) {
        case 'bintro':    app.innerHTML = renderBIntro();    break;
        case 'bquestion': app.innerHTML = renderBQuestion(); break;
        case 'bresults':  app.innerHTML = renderBResults();  break;
      }
      if (!playing) window.scrollTo({ top: 0, behavior: 'instant' });
    }

    document.addEventListener('click', (ev) => {
      const el = ev.target.closest('[data-action]');
      if (!el) return;
      switch (el.dataset.action) {
        case 'home':         window.location.href = '/'; break;
        case 'startblitz':   startBlitz(); break;
        case 'bpick':        lockBlitz(parseInt(el.dataset.idx)); break;
        case 'share':        doShare(); break;
        case 'share-tiktok': doShareTikTok(); break;
        case 'share-insta':  doShareInsta(); break;
      }
    });

    document.getElementById('nav-random').addEventListener('click', openRandom);

    document.addEventListener('keydown', (ev) => {
      if (state.view !== 'bquestion' || state.bLocked) return;
      const idx = { '1': 0, '2': 1, '3': 2, '4': 3 }[ev.key];
      if (idx === undefined) return;
      const blitz = blitzes[state.activeBlitzId];
      const bq = blitz?.questions[state.bIndex];
      if (bq && idx < bq.options.length) { ev.preventDefault(); lockBlitz(idx); }
    });

    const todayBlitzId = getTodayBlitzId();
    document.getElementById('nav-blitz').href = `/blitz/${todayBlitzId}`;
    document.getElementById('footer-blitz').href = `/blitz/${todayBlitzId}`;

    render();
  </script>

  <!-- Cookie consent banner -->
  <div id="cq-cookie" style="position:fixed;bottom:0;left:0;right:0;z-index:999;background:#1a1430;border-top:3px solid #3bffd2;padding:12px 22px;display:none;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;">
    <span style="font-family:'Bungee',cursive;font-size:11px;color:#fff;">🍪 We use cookies for advertising &amp; analytics. <a href="/privacy" style="color:#3bffd2;text-decoration:underline;">Privacy Policy</a></span>
    <div style="display:flex;gap:8px;flex-shrink:0;">
      <button id="cq-accept" style="background:#3bffd2;color:#1a1430;border:2px solid #3bffd2;box-shadow:3px 3px 0 #6c3bff;padding:8px 16px;font-family:'Bungee',cursive;font-size:10px;cursor:pointer;">ACCEPT</button>
      <button id="cq-decline" style="background:transparent;color:#b3a9d6;border:2px solid #b3a9d6;padding:8px 14px;font-family:'Bungee',cursive;font-size:10px;cursor:pointer;">NO THANKS</button>
    </div>
  </div>
  <script>
    (function () {
      var b = document.getElementById('cq-cookie');
      if (!b) return;
      if (!localStorage.getItem('cq-consent')) b.style.display = 'flex';
      document.getElementById('cq-accept').onclick = function () { localStorage.setItem('cq-consent', 'granted'); b.remove(); };
      document.getElementById('cq-decline').onclick = function () { localStorage.setItem('cq-consent', 'denied'); b.remove(); };
    })();
  </script>
</body>
</html>
