---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  jsonLd?: string;
}
const {
  title,
  description = "CrazyQuizzes — The Internet's Dumbest Quiz Site",
  canonical,
  ogImage = 'https://crazyquizzes.com/og-default.png',
  ogImageAlt,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, 'https://crazyquizzes.com').href;
const fullTitle = title.includes('CrazyQuizzes') ? title : `${title} — CrazyQuizzes`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="CrazyQuizzes" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt ?? fullTitle} />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt ?? fullTitle} />
  <meta name="theme-color" content="#6c3bff" />
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  <!-- Google AdSense Auto Ads -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3610150616518651" crossorigin="anonymous"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bungee&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    body {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      color: #1a1430;
      background-color: #f3eeff;
      background-image: linear-gradient(rgba(108,59,255,.08) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(108,59,255,.08) 1px, transparent 1px);
      background-size: 28px 28px;
      overflow-x: hidden;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: #fffdf7;
      border-bottom: 3px solid #1a1430;
      box-shadow: 0 4px 0 rgba(26,20,48,.12);
    }
    .header-inner {
      max-width: 1140px;
      margin: 0 auto;
      padding: 12px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      text-decoration: none;
    }
    @keyframes cq-spin { to { transform: rotate(360deg); } }
    .logo-star {
      font-family: 'Bungee', cursive;
      color: #6c3bff;
      display: inline-block;
      animation: cq-spin 7s linear infinite;
      font-size: 22px;
    }
    .logo-text { font-family: 'Bungee', cursive; font-size: clamp(18px, 3vw, 24px); letter-spacing: .01em; }
    .logo-text .crazy { color: #6c3bff; }
    .logo-text .quizzes { color: #1a1430; }

    nav {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      font-family: 'Bungee', cursive;
      font-size: 11px;
    }
    .nav-btn {
      cursor: pointer;
      text-decoration: none;
      color: #1a1430;
      border: 2px solid #1a1430;
      padding: 7px 12px;
      box-shadow: 3px 3px 0 #1a1430;
      transition: transform .1s, box-shadow .1s;
      background: #3bffd2;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      display: inline-block;
    }
    .nav-btn:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #1a1430; }
    .nav-btn.yellow { background: #ffd23f; }
    .nav-btn.pink { background: #ff3b9a; color: #fff; }
    .nav-plain {
      cursor: pointer;
      text-decoration: none;
      color: #1a1430;
      padding: 7px 6px;
      opacity: .7;
      font-family: 'Bungee', cursive;
      font-size: 11px;
    }

    .page-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 54px 22px 80px;
    }
    .page-badge {
      display: inline-block;
      font-family: 'Bungee', cursive;
      font-size: 11px;
      background: #1a1430;
      color: #3bffd2;
      padding: 6px 12px;
      border: 3px solid #1a1430;
      box-shadow: 4px 4px 0 #6c3bff;
      margin-bottom: 18px;
    }
    .page-title {
      font-family: 'Bungee', cursive;
      font-size: clamp(32px, 6vw, 56px);
      line-height: 1;
      margin: 0 0 24px;
    }
    .page-body {
      font-size: 15px;
      line-height: 1.7;
      color: #2d2250;
    }
    .page-body h2 {
      font-family: 'Bungee', cursive;
      font-size: 18px;
      margin: 36px 0 10px;
      color: #1a1430;
    }
    .page-body p { margin: 0 0 16px; }
    .page-body ul { margin: 0 0 16px; padding-left: 22px; }
    .page-body li { margin-bottom: 6px; }
    .page-body a { color: #6c3bff; text-decoration: underline; }

    .contact-card {
      background: #fffdf7;
      border: 3px solid #1a1430;
      box-shadow: 6px 6px 0 #1a1430;
      padding: 28px 32px;
      margin-top: 32px;
    }
    .contact-card h2 { margin-top: 0; }
    .contact-email {
      display: inline-block;
      font-family: 'Bungee', cursive;
      font-size: 18px;
      color: #6c3bff;
      text-decoration: none;
      border-bottom: 3px solid #6c3bff;
    }

    footer {
      background: #1a1430;
      border-top: 3px solid #1a1430;
      color: #fff;
      margin-top: 0;
    }
    .footer-inner {
      max-width: 1140px;
      margin: 0 auto;
      padding: 40px 22px 24px;
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
      align-items: flex-start;
    }
    .footer-brand { max-width: 300px; }
    .footer-logo { font-family: 'Bungee', cursive; font-size: 22px; margin-bottom: 10px; }
    .footer-logo .crazy { color: #3bffd2; }
    .footer-logo .quizzes { color: #fff; }
    .footer-desc { font-size: 13px; line-height: 1.5; color: #b3a9d6; margin: 0 0 14px; }
    .footer-tagline { font: 600 10px/1 'Courier New', monospace; color: #3bffd2; letter-spacing: .1em; }
    .footer-sitemap { font-family: 'Bungee', cursive; font-size: 11px; display: flex; flex-direction: column; gap: 10px; }
    .footer-sitemap .label { color: #ff3b9a; }
    .footer-sitemap .label:not(:first-child) { margin-top: 8px; }
    .footer-sitemap a { color: #fff; text-decoration: none; cursor: pointer; }
    .footer-sitemap a:hover { color: #3bffd2; }
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,.12);
      max-width: 1140px;
      margin: 0 auto;
      padding: 16px 22px;
      font-size: 12px;
      color: #b3a9d6;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo" aria-label="Go home">
        <span class="logo-star">✦</span>
        <span class="logo-text"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></span>
      </a>
      <nav>
        <a href="/" class="nav-btn">QUIZZES</a>
        <a href="/#daily-blitz" class="nav-btn yellow">⚡ DAILY BLITZ</a>
        <a href="/" class="nav-btn pink">🎲 RANDOM</a>
        <a href="/about" class="nav-plain">ABOUT</a>
      </nav>
    </div>
  </header>

  <div class="page-wrap">
    <slot />
  </div>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo"><span class="crazy">CRAZY</span><span class="quizzes">QUIZZES</span></div>
        <p class="footer-desc">Diagnosing your personality with snacks since right now. Results may be used against you in the group chat.</p>
        <div class="footer-tagline">★ BEST VIEWED IN NETSCAPE NAVIGATOR 4.0 ★</div>
        <a href="https://www.pinterest.com/crazyquizzes/" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;margin-top:14px;background:#e60023;color:#fff;font-family:'Bungee',cursive;font-size:11px;padding:8px 14px;border:2px solid #1a1430;box-shadow:3px 3px 0 #1a1430;text-decoration:none;"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>PINTEREST</a>
      </div>
      <div class="footer-sitemap">
        <span class="label">QUIZZES</span>
        <a href="/">All Quizzes</a>
        <a href="/personality-quizzes">Personality Quizzes</a>
        <a href="/trivia-quizzes">Trivia Blitzes</a>
        <span class="label">COMPANY</span>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Use</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 CrazyQuizzes.com — made with ♥ and zero focus groups</span>
      <span>crazyquizzes.com</span>
    </div>
  </footer>
  <!-- Cookie consent banner -->
  <div id="cq-cookie" style="position:fixed;bottom:0;left:0;right:0;z-index:999;background:#1a1430;border-top:3px solid #3bffd2;padding:12px 22px;display:none;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;">
    <span style="font-family:'Bungee',cursive;font-size:11px;color:#fff;">🍪 We use cookies for advertising &amp; analytics. <a href="/privacy" style="color:#3bffd2;text-decoration:underline;">Privacy Policy</a></span>
    <div style="display:flex;gap:8px;flex-shrink:0;">
      <button id="cq-accept" style="background:#3bffd2;color:#1a1430;border:2px solid #3bffd2;box-shadow:3px 3px 0 #6c3bff;padding:8px 16px;font-family:'Bungee',cursive;font-size:10px;cursor:pointer;">ACCEPT</button>
      <button id="cq-decline" style="background:transparent;color:#b3a9d6;border:2px solid #b3a9d6;padding:8px 14px;font-family:'Bungee',cursive;font-size:10px;cursor:pointer;">NO THANKS</button>
    </div>
  </div>
  <script>
    (function () {
      var b = document.getElementById('cq-cookie');
      if (!b) return;
      if (!localStorage.getItem('cq-consent')) b.style.display = 'flex';
      document.getElementById('cq-accept').onclick = function () { localStorage.setItem('cq-consent', 'granted'); b.remove(); };
      document.getElementById('cq-decline').onclick = function () { localStorage.setItem('cq-consent', 'denied'); b.remove(); };
    })();
  </script>
</body>
</html>
